---
import Seo from '../components/SeoTags.astro';
import SeoIcons from '../components/SeoIcons.astro';
import SkipLink from '../components/SkipLink.astro';
import ThemePreview from '../components/ThemePreviewPanel.astro';
import Tweaks from '../components/Tweaks.astro';
const DEV = import.meta.env.DEV;
export interface Props { title?: string; description?: string; path?: string; image?: string; robots?: string }
const { title, description, path='/', image, robots } = Astro.props;
---
<!doctype html>
<html lang="en" class="no-js" data-theme="twilight">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <Seo {title} {description} {path} {image} {robots} />
    <SeoIcons pinnedColor="#0EA5E9" themeColor="#0B1220" />
    <script is:inline>
(function(){
  var KEY='artagon.theme', ALLOWED=['midnight','twilight'], DEF='twilight';
  // Preview override via URL (?theme=twilight[&persist=1])
  try {
    var sp = new URLSearchParams(location.search);
    var override = sp.get('theme');
    if (override) {
      var t = (ALLOWED.indexOf(override) >= 0) ? override : DEF;
      document.documentElement.setAttribute('data-theme', t);
      if (sp.get('persist') === '1') localStorage.setItem(KEY, t);
      return;
    }
  } catch(e){}
  // Persisted choice — validate against allowlist, fall back to DEF
  try {
    var saved = localStorage.getItem(KEY);
    var theme = (saved && ALLOWED.indexOf(saved) >= 0) ? saved : DEF;
    document.documentElement.setAttribute('data-theme', theme);
  } catch(e) {
    document.documentElement.setAttribute('data-theme', DEF);
  }
})();
    </script>
    <link rel="stylesheet" href="/assets/theme.css" />
    <slot name="head" />
    <slot name="json-ld" />
    <slot name="indexation" />
    <slot name="branding" />
    <script>document.documentElement.classList.remove('no-js');function toggleMenu(){const m=document.getElementById('menu');if(m){m.hidden=!m.hidden;}var b=document.getElementById('menu-btn');if(b){b.setAttribute('aria-expanded', String(!m.hidden));}}</script>
    <script is:inline>
window.__setTheme = function(t){
  var KEY='artagon.theme', ALLOWED=['midnight','twilight'], DEF='twilight';
  var theme = (typeof t === 'string' && ALLOWED.indexOf(t) >= 0) ? t : DEF;
  document.documentElement.setAttribute('data-theme', theme);
  try { localStorage.setItem(KEY, theme); } catch(e){}
  // Sync browser UI with --bg
  try {
    var bg = getComputedStyle(document.documentElement).getPropertyValue('--bg').trim() || '#0B1220';
    var meta = document.querySelector('meta[name="theme-color"]');
    if (meta) meta.setAttribute('content', bg);
  } catch(e){}
  // Sync ThemeToggle buttons
  var pressed = theme === 'twilight';
  var label = pressed ? 'Switch to midnight theme' : 'Switch to twilight theme';
  document.querySelectorAll('[data-theme-toggle]').forEach(function(btn){
    btn.setAttribute('aria-pressed', String(pressed));
    btn.setAttribute('aria-label', label);
  });
};
    </script>
  </head>
  <body>
    <SkipLink />
    <slot name="header" />
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
    <slot name="footer" />
    <noscript>Your browser has JavaScript disabled. The site still works.</noscript>
    {DEV && <ThemePreview />}
    <Tweaks />
  </body>
</html>
