---
const path = Astro.url.pathname;
const active = (href: string) => path === href || path.startsWith(href + '/');

// Spec §3.1 calls for "Platform · Use cases · Standards · Writing".
// /use-cases, /standards, /writing routes ship in USMR Phase 4-5 — until
// then they would 404 and break the lychee link-check. Restore the full
// list when those routes exist.
const navLinks = [
  { href: '/platform',   text: 'Platform' },
  { href: '/vision',     text: 'Vision' },
  { href: '/roadmap',    text: 'Roadmap' },
  { href: '/docs',       text: 'Docs' },
] as const;
---
<header class="site-nav">
  <div class="nav-inner wrap">
    <a class="nav-wordmark" href="/" aria-label="Artagon home">
      <img src="/icons/icon-64.png" alt="" width="28" height="28" aria-hidden="true" />
      <span>Artagon</span>
    </a>

    <nav aria-label="Primary">
      <ul class="nav-links" role="list">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class={active(link.href) ? 'active' : undefined}
              aria-current={active(link.href) ? 'page' : undefined}
            >
              {link.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="nav-right">
      <a
        class="nav-github"
        href="https://github.com/artagon"
        rel="noopener noreferrer"
        aria-label="Artagon on GitHub"
      >
        <!-- GitHub icon (Octicon mark-github) -->
        <svg aria-hidden="true" focusable="false" width="20" height="20" viewBox="0 0 16 16" fill="currentColor">
          <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38
            0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13
            -.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66
            .07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95
            0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12
            0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27
            1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15
            0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48
            0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
        </svg>
      </a>
    </div>
  </div>
</header>

<style>
.site-nav {
  position: sticky;
  top: 0;
  z-index: 50;
  height: 64px;
  background: color-mix(in srgb, var(--bg) 72%, transparent);
  border-bottom: 1px solid var(--line-soft);
  backdrop-filter: saturate(150%) blur(12px);
  -webkit-backdrop-filter: saturate(150%) blur(12px);
}

.nav-inner {
  display: grid;
  grid-template-columns: auto 1fr auto;
  align-items: center;
  gap: 1rem;
  height: 64px;
}

.nav-wordmark {
  display: inline-flex;
  align-items: center;
  gap: 0.6rem;
  color: var(--fg);
  text-decoration: none;
  font-weight: 600;
  font-size: 1rem;
  line-height: 1;
  white-space: nowrap;
}

.nav-wordmark:hover {
  color: var(--accent);
}

nav[aria-label="Primary"] {
  display: flex;
  justify-content: center;
}

.nav-links {
  display: flex;
  align-items: center;
  gap: 0.25rem;
  list-style: none;
  margin: 0;
  padding: 0;
}

.nav-links a {
  display: inline-flex;
  align-items: center;
  height: 36px;
  padding: 0 0.75rem;
  color: var(--fg-1);
  text-decoration: none;
  border-radius: 8px;
  border: 1px solid transparent;
  font-size: 0.9rem;
  transition: color 0.15s ease, background 0.15s ease, border-color 0.15s ease;
  position: relative;
}

.nav-links a::after {
  content: '';
  position: absolute;
  bottom: 3px;
  left: 50%;
  transform: translateX(-50%);
  width: 0;
  height: 2px;
  background: var(--accent);
  border-radius: 1px;
  transition: width 0.2s ease;
}

.nav-links a:hover {
  color: var(--fg);
  background: color-mix(in srgb, var(--accent) 6%, transparent);
}

.nav-links a:hover::after {
  width: 60%;
}

.nav-links a.active,
.nav-links a[aria-current="page"] {
  color: var(--fg);
  border-color: color-mix(in srgb, var(--accent) 35%, transparent);
  background: color-mix(in srgb, var(--accent) 8%, transparent);
}

.nav-links a.active::after,
.nav-links a[aria-current="page"]::after {
  width: 60%;
}

.nav-right {
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.nav-github {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 34px;
  height: 34px;
  color: var(--fg-2);
  border: 1px solid var(--line);
  border-radius: 8px;
  text-decoration: none;
  transition: color 0.15s ease, border-color 0.15s ease, background 0.15s ease;
}

.nav-github:hover {
  color: var(--fg);
  border-color: var(--accent);
  background: color-mix(in srgb, var(--accent) 8%, transparent);
}

/* Focus rings */
.nav-wordmark:focus-visible,
.nav-links a:focus-visible,
.nav-github:focus-visible {
  outline: 2px solid var(--accent);
  outline-offset: 2px;
}

/* Anchor targets hidden under sticky nav — use nav height + small buffer */
:global(:target) {
  scroll-margin-top: 72px;
}

@media (max-width: 640px) {
  .nav-links {
    display: none;
  }
}
</style>
