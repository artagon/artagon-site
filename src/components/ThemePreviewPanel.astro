---
// USMR site-navigation §"Theme Toggle" allow-list is binary
// (twilight ↔ midnight). The slate pack was retired in pt167 — its
// `:root[data-theme="slate"]` block no longer exists in theme.css
// (theme.css line 298 carries the removal narrative). Iterating
// slate here would silently fall through to the unstyled default
// cascade rather than render an alternate palette; the dev preview
// matches the live cascade by enumerating only the two retained
// user-toggleable variants.
const THEMES = ['twilight', 'midnight'] as const;
---
<div class="theme-panel" aria-label="Theme preview panel">
  {/* USMR Phase 5.5.16-pt137 — explicit type="button" per project
      contract; prevents default-submit if ever embedded in a form.
      USMR Phase 5.5.16-pt174 — replaced inline `onClick={...}` (which
      Astro emits as `onclick="..."` in the rendered HTML, an inline
      event-handler that violates project CSP discipline — see
      `scripts/csp.mjs` strict-no-unsafe-inline gate) with a delegated
      data-attribute click handler. Matches the canonical pattern
      established by `Header.astro` (`[data-nav-toggle]`) and the
      `[data-theme-toggle]` sync hook in `BaseLayout.astro`. */}
  {THEMES.map(t => <button type="button" data-theme-target={t}>{t}</button>)}
</div>

<script>
  // USMR Phase 5.5.16-pt174 — programmatic click binding for the dev
  // ThemePreviewPanel. `__setTheme` is defined in BaseLayout.astro's
  // is:inline script and validates against the same allow-list, so any
  // unexpected `data-theme-target` value collapses to the project
  // default ('twilight'). No innerHTML / outerHTML / inline-handler.
  declare global {
    interface Window {
      __setTheme?: (t: string) => void;
    }
  }
  document
    .querySelectorAll<HTMLButtonElement>("[data-theme-target]")
    .forEach((btn) => {
      btn.addEventListener("click", () => {
        const target = btn.dataset.themeTarget;
        if (target && typeof window.__setTheme === "function") {
          window.__setTheme(target);
        }
      });
    });
</script>

<style>
.theme-panel {
  position: fixed; right: 12px; bottom: 12px; z-index: 9999;
  background: var(--bg-1); border:1px solid color-mix(in srgb, var(--line) 70%, transparent);
  border-radius:12px; padding:10px; display:flex; gap:.5rem;
}
.theme-panel button {
  background: var(--bg); color: var(--fg);
  border:1px solid color-mix(in srgb, var(--line) 70%, transparent);
  border-radius:8px; padding:.35rem .6rem; cursor:pointer;
}
.theme-panel button:focus-visible { outline:2px solid var(--accent); outline-offset:2px; }
</style>
