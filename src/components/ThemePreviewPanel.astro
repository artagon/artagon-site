---
// USMR site-navigation §"Theme Toggle" allow-list is binary
// (twilight ↔ midnight). The slate pack still exists in theme.css but
// is no longer user-toggleable; drop it from the dev preview to match
// __setTheme's allow-list (it would silently collapse to twilight).
const THEMES = ['twilight', 'midnight'];
---
<div class="theme-panel" aria-label="Theme preview panel">
  {/* USMR Phase 5.5.16-pt137 — explicit type="button" per project
      contract; prevents default-submit if ever embedded in a form. */}
  {THEMES.map(t => <button type="button" onClick={`__setTheme('${t}')`}>{t}</button>)}
</div>

<style>
.theme-panel {
  position: fixed; right: 12px; bottom: 12px; z-index: 9999;
  background: var(--bg-1); border:1px solid color-mix(in srgb, var(--line) 70%, transparent);
  border-radius:12px; padding:10px; display:flex; gap:.5rem;
}
.theme-panel button {
  background: var(--bg); color: var(--fg);
  border:1px solid color-mix(in srgb, var(--line) 70%, transparent);
  border-radius:8px; padding:.35rem .6rem; cursor:pointer;
}
.theme-panel button:focus-visible { outline:2px solid var(--accent); outline-offset:2px; }
</style>
