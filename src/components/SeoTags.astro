---
import taglines from '../content/taglines.json';
import { safeJsonLd } from '../lib/charset';

// USMR Phase 5.1q + post-review hardening. The Article variant of
// the Props union requires `publishedTime` (and accepts the optional
// `modifiedTime` / `author` / `tags`) — this makes a malformed article
// a compile-time error rather than a silent runtime "Article JSON-LD
// dropped" surprise.
interface BaseProps {
  title?: string;
  description?: string;
  path?: string;
  image?: string;
  robots?: string;
}
interface WebsiteProps extends BaseProps {
  type?: 'website';
}
interface ArticleProps extends BaseProps {
  type: 'article';
  /** ISO 8601 publish date — required for articles. */
  publishedTime: string;
  modifiedTime?: string;
  author?: string;
  tags?: readonly string[];
}
export type Props = WebsiteProps | ArticleProps;
// Discriminated-union narrowing: read the raw props, then derive each
// field. We extract `type` first so subsequent reads can narrow on
// `type === 'article'` without re-asserting the cast. A malformed
// caller (`{type:'article'}` without `publishedTime`) fails type-check
// AT THE CALLSITE — the narrowing here just keeps the SeoTags body
// honest about which fields exist in each branch.
// USMR Phase 5.5.14 — discriminated-union narrowing without casts.
// Astro.props is typed `Props = WebsiteProps | ArticleProps`.
// Reading via the union directly + type-guarding on `props.type ===
// 'article'` lets TS narrow `publishedTime` into existence inside the
// guard without any `as` cast. The earlier triple-cast (lines 36, 39,
// 50, 51) erased the union's narrowing guarantees — a future variant
// addition would have compiled silently. The runtime throw stays as
// a defense-in-depth backstop in case a caller bypasses the
// type-checker (e.g. dynamic JSX consumers).
const props = Astro.props;
const type = props.type ?? 'website';
const isArticle = props.type === 'article';
if (isArticle && !props.publishedTime) {
  throw new Error(
    "SeoTags: type='article' requires publishedTime (ISO 8601).",
  );
}
const articleProps: ArticleProps | null = isArticle ? props : null;
const {
  title = 'Artagon — Trusted Identity for Machines and Humans',
  description = `Passkeys, verifiable credentials, attested clients, and graph-native policy — ${taglines.tagline.full}`,
  path = '/',
  image = '/assets/logos/og-image.png',
  robots,
} = props;
const publishedTime = articleProps?.publishedTime;
const modifiedTime = articleProps?.modifiedTime;
const author = articleProps?.author ?? 'Artagon';
const tags: readonly string[] = articleProps?.tags ?? [];
const SITE = (Astro.site ?? new URL('https://artagon.com')).toString().replace(/\/$/, '');
const url = `${SITE}${path.startsWith('/') ? path : `/${path}`}`;
const motto = taglines.tagline.full;
// USMR Phase 5.5.16-pt149 — three-way guard on the motto append:
//   1) Skip if description already contains "Verified, Private,
//      Attested" (legacy condition; intentional motto inline).
//   2) Skip if description already mentions the motto's
//      distinguishing phrase "Trusted Identity for Machines and
//      Humans" (some pages — like home — paraphrase it).
//   3) **NEW**: Skip if description is already long enough that
//      appending the 76-char motto would push past Google's ~160
//      char SERP truncation cutoff. pt144 brought every page
//      description up to 150-180 chars; appending the motto pushed
//      every rendered meta-description to 184-245 chars, with the
//      motto invisibly truncated on every SERP. The 90-char floor
//      below leaves room for the appended " — {76-char motto}" to
//      land at ≤166 chars total.
const trimmedDescription = description.trim();
const skipMottoAppend =
  /Verified\W+Private\W+Attested/i.test(trimmedDescription) ||
  /Trusted Identity for Machines and Humans/i.test(trimmedDescription) ||
  trimmedDescription.length >= 90;
const metaDescription = skipMottoAppend
  ? trimmedDescription
  : `${trimmedDescription} — ${motto}`;
const ogImageAbsolute = image.startsWith('http') ? image : `${SITE}${image.startsWith('/') ? image : `/${image}`}`;
// USMR Phase 5.5.16-pt148 — pre-pt148 the og:image:alt unconditionally
// appended ` — Artagon` to title, producing "Platform — Artagon —
// Artagon" / "FAQ — Artagon — Artagon" / etc. (because every page's
// title already ends with the canonical suffix per DESIGN.md §9.5)
// AND "Artagon — Trusted Identity ... — Artagon" on the home page
// (which uses the §9.5 brand-first carve-out). Skip the append when
// the title already mentions Artagon (suffix OR prefix). Mirrors the
// metaDescription guard one line up.
const ogImageAlt = /^Artagon\b|—\sArtagon$/.test(title)
  ? title
  : `${title} — Artagon`;

// USMR Phase 5.1q.8 — site-wide WebSite + BreadcrumbList JSON-LD.
const segments = path.replace(/^\/+|\/+$/g, '').split('/').filter(Boolean);
function safeDecode(seg: string): string {
  try {
    return decodeURIComponent(seg);
  } catch {
    // Malformed `%`-escapes throw URIError. Fall back to the raw
    // segment so a bad path doesn't crash the SSR render.
    return seg;
  }
}
const breadcrumbItems = [
  { name: 'Home', item: `${SITE}/` },
  ...segments.map((seg, i) => ({
    name: safeDecode(seg).replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase()),
    item: `${SITE}/${segments.slice(0, i + 1).map(encodeURIComponent).join('/')}`,
  })),
];

// Critical hardening (post-5.1q review): see src/lib/charset.ts for the
// rationale and escape-table coverage. We delegate to a shared helper
// so all inline-JSON-LD-emitting components share the same hardened
// pipeline (and tests).
//
// Sentinel: keep this comment block here so a future inline regression
// is caught by reviewers; the helper at src/lib/charset.ts is the
// single load-bearing path for inline JSON-LD escaping.

const orgLd = safeJsonLd({
  "@context":"https://schema.org","@type":"Organization","name":"Artagon",
  "url":`${SITE}/`,
  "logo":`${SITE}/assets/logos/logo-square-512.png`,
  "slogan":taglines.tagline.full,
  "sameAs":["https://github.com/artagon"]
});
const serviceLd = safeJsonLd({
  "@context":"https://schema.org","@type":"Service","name":"Artagon Identity Platform",
  "serviceType":"Identity and Access Management (IAM)","provider":{"@type":"Organization","name":"Artagon","url":`${SITE}/`},
  "areaServed":"Worldwide","url":`${SITE}/`,
  "description":`The Unified Identity Platform for Machines and Humans. OIDC 2.1 OpenID Provider with PAR, JAR, JARM, DPoP, mTLS. GNAP Authorization Server with proof-of-possession. Verifiable Credentials using SD-JWT and BBS+ via OID4VCI/VP. Passkey-first authentication (WebAuthn/FIDO2). Device and app attestation (Android Play Integrity, Apple App Attest). Zanzibar-style relationship graph with PDP policy engine (XACML, Cedar, OPA). Zero-knowledge selective disclosure. Privacy-by-design identity infrastructure. ${taglines.tagline.short}`
});
const websiteLd = safeJsonLd({
  "@context":"https://schema.org","@type":"WebSite","name":"Artagon",
  "url":`${SITE}/`,
  "potentialAction":{
    "@type":"SearchAction",
    "target":{"@type":"EntryPoint","urlTemplate":`${SITE}/search/?q={search_term_string}`},
    "query-input":"required name=search_term_string"
  }
});
// Per schema.org rich-snippet rules, BreadcrumbList needs ≥ 2 items to
// render — emit only when we're past the root.
//
// USMR Phase 5.5.16-pt150 — also skip when the page is `noindex`.
// BreadcrumbList tells crawlers "this URL exists as a navigable
// destination at position N in a hierarchy"; noindex says "don't
// index this URL". Emitting both is the same mixed-signal class
// pt146 caught for the sitemap. Pre-pt150 /404 shipped a "Home →
// 404" breadcrumb even though pt145 had noindexed it; same for the
// 8 shim/dev routes. Now BreadcrumbList ships only for indexable
// inner routes (faq / platform / roadmap / standards / use-cases /
// vision / writing[/slug] / get-started / bridge).
const isNoindex = robots !== undefined && /\bnoindex\b/i.test(robots);
const breadcrumbLd =
  breadcrumbItems.length >= 2 && !isNoindex
    ? safeJsonLd({
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        itemListElement: breadcrumbItems.map((c, i) => ({
          "@type": "ListItem",
          position: i + 1,
          name: c.name,
          item: c.item,
        })),
      })
    : null;
const articleLd = type === 'article' && publishedTime ? safeJsonLd({
  "@context":"https://schema.org","@type":"Article",
  "headline":title,"description":metaDescription,
  "datePublished":publishedTime,
  ...(modifiedTime ? { "dateModified": modifiedTime } : {}),
  "image":[ogImageAbsolute],
  "author":{"@type":"Organization","name":author},
  "publisher":{"@type":"Organization","name":"Artagon","logo":{"@type":"ImageObject","url":`${SITE}/assets/logos/logo-square-512.png`}},
  "url":url,
  ...(tags.length ? { "keywords": tags.join(', ') } : {}),
}) : null;
---
<title>{title}</title>
<meta name="description" content={metaDescription} />
<link rel="canonical" href={url} />
{robots && <meta name="robots" content={robots} />}
<meta property="og:title" content={title} />
<meta property="og:description" content={metaDescription} />
<meta property="og:site_name" content="Artagon" />
<meta property="og:url" content={url} />
<meta property="og:type" content={type} />
<meta property="og:locale" content="en_US" />
<meta property="og:image" content={ogImageAbsolute} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={ogImageAlt} />
{type === 'article' && publishedTime && (
  <meta property="article:published_time" content={publishedTime} />
)}
{type === 'article' && modifiedTime && (
  <meta property="article:modified_time" content={modifiedTime} />
)}
{type === 'article' && tags.map((t) => (
  <meta property="article:tag" content={t} />
))}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@artagon" />
<meta name="twitter:creator" content="@artagon" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={metaDescription} />
<meta name="twitter:image" content={ogImageAbsolute} />
<meta name="twitter:image:alt" content={ogImageAlt} />
<script type="application/ld+json" set:html={orgLd}></script>
<script type="application/ld+json" set:html={serviceLd}></script>
<script type="application/ld+json" set:html={websiteLd}></script>
{breadcrumbLd && (
  <script type="application/ld+json" set:html={breadcrumbLd}></script>
)}
{articleLd && (
  <script type="application/ld+json" set:html={articleLd}></script>
)}
