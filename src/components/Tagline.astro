---
import taglines from '../content/taglines.json';
const { variant = 'inline', class: cls = '' } = Astro.props;
const { tagline } = taglines;
const text =
  variant === 'full'     ? tagline.full :
  variant === 'sentence' ? tagline.short :
  variant === 'abbr'     ? tagline.abbr :
                           tagline.inline;
---
<span class={`pill ${cls}`} aria-label="Company motto">{text}</span>
