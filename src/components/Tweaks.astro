---
/**
 * Tweaks — dev-only design tinkerer panel.
 *
 * The script is gated on `import.meta.env.DEV`. In production builds, Astro
 * statically eliminates the entire conditional block (and its dynamic import),
 * so neither the inline custom-element registration nor `tweaks.ts` ever
 * reaches the production bundle. CSP/SRI surface stays clean.
 *
 * State persists in localStorage under `artagon.tweaks.v1` and projects
 * onto `data-accent`, `data-density`, `data-theme`, `data-hero-font` on
 * `<html>` plus `.no-grid` on `<body>` — the same contract the upstream
 * design's CSS already keys off.
 *
 * Toggle: `⌘⇧T` (or `Ctrl+Shift+T` on non-mac), or click the trigger button.
 */
const isDev = import.meta.env.DEV;
---

{
  isDev && (
    <>
      <artagon-tweaks aria-live="polite"></artagon-tweaks>
      <script>import "../scripts/tweaks.ts";</script>
      <style>
        artagon-tweaks {
          position: fixed;
          right: 12px;
          bottom: 12px;
          z-index: 10000;
          font-family:
            ui-monospace,
            Menlo,
            Consolas,
            monospace;
          font-size: 12px;
          color: var(--text, #e2e8f0);
        }
        .tweaks-trigger {
          appearance: none;
          background: var(--surface, #0f172a);
          color: var(--text, #e2e8f0);
          border: 1px solid var(--border, #1e293b);
          padding: 6px 10px;
          border-radius: 8px;
          cursor: pointer;
          letter-spacing: 0.06em;
          text-transform: lowercase;
          opacity: 0.6;
          transition:
            opacity 0.18s ease,
            transform 0.18s ease;
        }
        @media (prefers-reduced-motion: reduce) {
          .tweaks-trigger,
          .tweaks-opt {
            transition: none;
          }
        }
        .tweaks-trigger:hover,
        .tweaks-trigger[aria-expanded="true"] {
          opacity: 1;
        }
        .tweaks-swatch {
          display: inline-block;
          width: 16px;
          height: 16px;
          border-radius: 3px;
          margin-right: 6px;
          vertical-align: -3px;
          border: 1px solid var(--border, #1e293b);
        }
        .tweaks-panel {
          position: absolute;
          right: 0;
          bottom: calc(100% + 8px);
          width: 280px;
          max-height: 70vh;
          overflow-y: auto;
          padding: 14px 16px 12px;
          background: var(--surface, #0f172a);
          border: 1px solid var(--border, #1e293b);
          border-radius: 12px;
          box-shadow: 0 12px 32px rgba(0, 0, 0, 0.45);
        }
        .tweaks-panel[hidden] {
          display: none;
        }
        .tweaks-header {
          display: flex;
          justify-content: space-between;
          align-items: center;
          margin: 0 0 12px;
        }
        .tweaks-header h4 {
          margin: 0;
          font-size: 13px;
          font-weight: 600;
          letter-spacing: 0.02em;
        }
        .tweaks-header kbd {
          font-size: 10px;
          font-family: inherit;
          padding: 2px 6px;
          border: 1px solid var(--border, #1e293b);
          border-radius: 4px;
          background: rgba(255, 255, 255, 0.04);
        }
        .tweaks-field {
          border: 0;
          padding: 0;
          margin: 0 0 10px;
        }
        .tweaks-field legend {
          font-size: 10px;
          letter-spacing: 0.18em;
          text-transform: uppercase;
          color: var(--muted, #94a3b8);
          padding: 0;
          margin-bottom: 6px;
        }
        .tweaks-opts {
          display: flex;
          flex-wrap: wrap;
          gap: 4px;
        }
        .tweaks-opt {
          appearance: none;
          background: transparent;
          color: var(--text, #e2e8f0);
          border: 1px solid var(--border, #1e293b);
          padding: 4px 8px;
          border-radius: 6px;
          cursor: pointer;
          font: inherit;
          font-size: 11px;
          text-transform: lowercase;
          transition:
            background 0.15s ease,
            border-color 0.15s ease;
        }
        .tweaks-opt:hover {
          border-color: var(--brand-teal, #22e3c5);
        }
        .tweaks-opt.is-active {
          background: var(--brand-teal, #22e3c5);
          color: #041016;
          border-color: var(--brand-teal, #22e3c5);
        }
        .tweaks-footer {
          margin-top: 8px;
          padding-top: 8px;
          border-top: 1px solid var(--border, #1e293b);
          font-size: 10px;
          color: var(--muted, #94a3b8);
          line-height: 1.5;
        }
      </style>
    </>
  )
}
