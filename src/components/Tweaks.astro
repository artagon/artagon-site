---
/**
 * Tweaks — dev-only design tinkerer panel.
 *
 * Renders as a React island faithful to upstream
 * `new-design/extracted/src/layouts/BaseLayout.jsx:312-359`.
 *
 * Mount is gated on `import.meta.env.DEV`: the `{isDev && …}` conditional
 * is statically evaluated in production builds, so no HTML references the
 * island and no browser fetches it. (Vite still emits the compiled chunk
 * to `_astro/TweaksPanel.[hash].js` because the static `import` statement
 * is reachable; that chunk is orphaned and is not worth a dynamic-import
 * workaround. Re-measure the byte cost if the panel grows substantially.)
 *
 * The React runtime IS shipped to production. Other interactive surfaces
 * (`/play`, `/console`, `/search`) will use it; Tweaks pays the entry cost.
 *
 * State persists in localStorage under `artagon.tweaks.v2` and projects
 * onto `data-accent`, `data-density`, `data-theme`, `data-hero-font` on
 * `<html>` plus `.no-grid` on `<body>` — the same contract upstream CSS
 * keys off.
 *
 * Pre-paint: an `is:inline` boot script reads localStorage and applies the
 * 4 data-attrs + body class synchronously before the page renders. The
 * React island hydrates after `client:idle` and takes over for
 * interactivity. Without the inline restore, the four non-`data-theme`
 * attributes would flicker on every dev reload.
 *
 * Toggle: `⌘.` (or `Ctrl+.` on non-mac), `Esc` to close.
 */
import TweaksPanel from "./TweaksPanel.tsx";
const isDev = import.meta.env.DEV;
---

{
  isDev && (
    <>
      {/* Pre-paint restore: synchronously apply persisted Tweaks state to
          the DOM before React hydrates. Mirrors BaseLayout.astro's
          theme-restore pattern. Dev-only — gated by `isDev`. */}
      <script is:inline>
        (function () {
          try {
            const raw = localStorage.getItem("artagon.tweaks.v3");
            if (!raw) return;
            const t = JSON.parse(raw);
            const html = document.documentElement;
            const accents = ["cyan", "violet", "amber", "lime"];
            const densities = ["dense", "comfortable", "roomy"];
            const themes = ["dark", "light"];
            const fonts = ["grotesk", "fraunces", "dmserif", "mono"];
            const widgets = ["in-hero", "A · strip", "B · 3-up", "C · split", "D · ticker", "off"];
            if (accents.indexOf(t.accent) >= 0) html.setAttribute("data-accent", t.accent);
            if (densities.indexOf(t.density) >= 0) html.setAttribute("data-density", t.density);
            if (themes.indexOf(t.theme) >= 0) html.setAttribute("data-theme", t.theme);
            if (fonts.indexOf(t.heroFont) >= 0) html.setAttribute("data-hero-font", t.heroFont);
            if (widgets.indexOf(t.writingWidget) >= 0) html.setAttribute("data-writing-widget", t.writingWidget);
            if (t.showGrid === false && document.body) document.body.classList.add("no-grid");
            else if (t.showGrid === false) {
              document.addEventListener("DOMContentLoaded", function () {
                document.body.classList.add("no-grid");
              });
            }
          } catch (e) {
            /* malformed localStorage — React island will fall back to DEFAULTS on hydrate */
          }
        })();
      </script>
      <div class="tweaks-host" aria-live="polite">
        <TweaksPanel client:idle />
      </div>
      <style is:global>
        .tweaks-host {
          position: fixed;
          right: 12px;
          bottom: 12px;
          z-index: 10000;
          font-family:
            ui-monospace,
            Menlo,
            Consolas,
            monospace;
          font-size: 12px;
          color: var(--fg);
        }
        .tweaks-trigger {
          appearance: none;
          background: var(--bg-1);
          color: var(--fg);
          border: 1px solid var(--line);
          padding: 6px 10px;
          border-radius: 8px;
          cursor: pointer;
          letter-spacing: 0.06em;
          text-transform: lowercase;
          opacity: 0.6;
          transition:
            opacity 0.18s ease,
            transform 0.18s ease;
        }
        @media (prefers-reduced-motion: reduce) {
          .tweaks-trigger,
          .tweaks-opt {
            transition: none;
          }
        }
        .tweaks-trigger:hover,
        .tweaks-trigger[aria-expanded="true"] {
          opacity: 1;
        }
        .tweaks-swatch {
          display: inline-block;
          width: 16px;
          height: 16px;
          border-radius: 3px;
          margin-right: 6px;
          vertical-align: -3px;
          border: 1px solid var(--line);
        }
        .tweaks-panel {
          position: absolute;
          right: 0;
          bottom: calc(100% + 8px);
          width: 280px;
          max-height: 70vh;
          overflow-y: auto;
          padding: 14px 16px 12px;
          background: var(--bg-1);
          border: 1px solid var(--line);
          border-radius: 12px;
          box-shadow: var(--elevation-5);
        }
        .tweaks-panel[hidden] {
          display: none;
        }
        .tweaks-header {
          display: flex;
          justify-content: space-between;
          align-items: center;
          margin: 0 0 12px;
        }
        .tweaks-header h4 {
          margin: 0;
          font-size: 13px;
          font-weight: 600;
          letter-spacing: 0.02em;
        }
        .tweaks-header kbd {
          font-size: 10px;
          font-family: inherit;
          padding: 2px 6px;
          border: 1px solid var(--line);
          border-radius: 4px;
          background: var(--chip-bg-neutral);
        }
        .tweaks-field {
          border: 0;
          padding: 0;
          margin: 0 0 10px;
        }
        .tweaks-field legend {
          font-size: 10px;
          letter-spacing: 0.18em;
          text-transform: uppercase;
          color: var(--fg-2);
          padding: 0;
          margin-bottom: 6px;
        }
        .tweaks-opts {
          display: flex;
          flex-wrap: wrap;
          gap: 4px;
        }
        .tweaks-opt {
          appearance: none;
          background: transparent;
          color: var(--fg);
          border: 1px solid var(--line);
          padding: 4px 8px;
          border-radius: 6px;
          cursor: pointer;
          font: inherit;
          font-size: 11px;
          text-transform: lowercase;
          transition:
            background 0.15s ease,
            border-color 0.15s ease;
        }
        .tweaks-opt:hover {
          border-color: var(--accent);
        }
        .tweaks-opt.is-active {
          background: var(--accent);
          color: var(--bg);
          border-color: var(--accent);
        }
        .tweaks-footer {
          margin-top: 8px;
          padding-top: 8px;
          border-top: 1px solid var(--line);
          font-size: 10px;
          color: var(--fg-2);
          line-height: 1.5;
        }
      </style>
    </>
  )
}
