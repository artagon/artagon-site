---
/**
 * SectionHeader component - Section wrapper with header, number, and intro text.
 *
 * @example Basic usage
 * <SectionHeader title="Executive Summary" number="01">
 *   <p>Content here.</p>
 * </SectionHeader>
 */
export interface Props {
  title: string;
  number?: string;
  intro?: string;
  class?: string;
  className?: string;
  id?: string;
}

const {
  title,
  number,
  intro,
  class: classNameProp = '',
  className = '',
  ...rest
} = Astro.props;

const classes = ['ui-section', classNameProp, className].filter(Boolean).join(' ');
---

{/* USMR Phase 5.5.16-pt140 — landmark labelling. Pass `aria-label`
    derived from the required `title` prop so every <section> rendered
    via SectionHeader is a real WCAG region landmark, not a generic
    div. The {...rest} spread takes precedence if a consumer passes
    an explicit aria-labelledby pointing at a different id (rare). */}
<section class={classes} aria-label={title} {...rest}>
  <div class="ui-section-header">
    <h2>{title}</h2>
    {number && <div class="ui-section-number">{number}</div>}
  </div>
  {intro && <p class="ui-section-intro">{intro}</p>}
  <slot />
</section>
