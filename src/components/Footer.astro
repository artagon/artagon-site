---
import { execSync } from 'node:child_process';
import pkg from '../../package.json';
import ArtagonGlyph from './ArtagonGlyph.astro';
import ThemeToggle from './ThemeToggle.astro';
import taglines from '../content/taglines.json';

const { tagline } = taglines;
const year = new Date().getFullYear();
const version = pkg.version;
// Prefer the CI-injected commit SHA so shallow clones don't fall back
// to 'unknown'. `git rev-parse` covers the local-dev path.
let gitSha = process.env.GITHUB_SHA?.slice(0, 7) ?? '';
if (!gitSha) {
  try {
    gitSha = execSync('git rev-parse --short HEAD', { timeout: 3000 }).toString().trim().slice(0, 7);
  } catch (e) {
    // Non-fatal: version string falls back to 'unknown' if git is
    // unavailable (e.g. tarball deploy with no .git).
    process.stderr.write(`Footer: could not read git SHA — ${e.message}\n`);
    gitSha = 'unknown';
  }
}
const versionString = `v${version} — build ${gitSha}`;

// USMR Phase 5.5.3 — footer columns rewritten to match the canonical
// new-design Footer (index.html lines 605-660). Canonical structure:
// Platform (5 pillar/route links) + Developers (5 dev resources) +
// Company (5 corporate) + Legal (5 legal docs). Placeholder hrefs for
// routes that don't yet exist in the Astro app (mailto / external /
// existing FAQ-style pages where appropriate).
const cols = [
  {
    label: 'Platform',
    links: [
      { href: '/platform',   text: 'Identity' },
      { href: '/platform',   text: 'Credentials' },
      { href: '/platform',   text: 'Authorization' },
      { href: '/bridge',     text: 'Bridge' },
      { href: '/use-cases',  text: 'Use cases' },
    ],
  },
  {
    label: 'Developers',
    links: [
      { href: '/docs',       text: 'Docs' },
      { href: '/developers', text: 'SDKs' },
      { href: '/play',       text: 'Playground' },
      { href: 'https://github.com/artagon', text: 'GitHub', external: true },
      { href: '/standards',  text: 'Standards' },
    ],
  },
  {
    label: 'Company',
    links: [
      { href: '/vision',     text: 'About' },
      { href: '/roadmap',    text: 'Roadmap' },
      { href: '/writing',    text: 'Writing' },
      { href: '/security',   text: 'Security' },
      { href: '/get-started', text: 'Contact' },
    ],
  },
  {
    // Legal placeholders match canonical (`new-design/extracted/src/pages/index.html:631-635`)
    // — only routes that exist resolve; the rest stay `'#'` until
    // dedicated pages ship. Routing a misleading link (`Terms → /privacy`)
    // would silently misdirect users — the silent-failure-hunter review
    // (5.5.4) flagged that as a Major content-trust regression.
    label: 'Legal',
    links: [
      { href: '/privacy',  text: 'Privacy' },
      { href: '#',         text: 'Terms' },
      { href: '#',         text: 'Trust center' },
      { href: '#',         text: 'DPA' },
      { href: '#',         text: 'Sub-processors' },
    ],
  },
] as const;
---
<footer role="contentinfo" class="site-footer">
  <div class="footer-inner wrap">
    <div class="footer-brand">
      <a href="/" class="footer-wordmark" aria-label="Artagon home">
        <ArtagonGlyph class="footer-glyph" />
        <span>Artagon</span>
      </a>
      <p class="footer-positioning">{tagline.positioning}</p>
      <div class="footer-theme">
        <ThemeToggle />
      </div>
    </div>

    <nav class="footer-cols" aria-label="Footer">
      {cols.map(col => (
        <div class="footer-col">
          <h3 class="footer-col-heading">{col.label}</h3>
          <ul role="list">
            {col.links.map(link => (
              <li>
                <a
                  href={link.href}
                  {...(('external' in link && link.external) ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                >
                  {link.text}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </nav>
  </div>

  <div class="footer-meta wrap">
    <span>© {year} Artagon, Inc. — Philadelphia, PA</span>
    <span class="footer-stack">Built on Astro · Open-source core · Apache 2.0</span>
    <span class="footer-version">{versionString}</span>
  </div>
</footer>

<style>
.site-footer {
  border-top: 1px solid var(--line-soft);
  background: var(--bg-1);
  color: var(--fg-1);
  padding-top: var(--space-12);
  padding-bottom: var(--space-8);
  font-size: 0.9rem;
}

.footer-inner {
  display: grid;
  grid-template-columns: 220px 1fr;
  gap: var(--space-12);
  padding-bottom: var(--space-10);
  border-bottom: 1px solid var(--line-soft);
}

.footer-brand {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}

.footer-wordmark {
  display: inline-flex;
  align-items: center;
  gap: 0.6rem;
  color: var(--fg);
  text-decoration: none;
  font-weight: 600;
  font-size: 1rem;
}

.footer-wordmark:hover {
  color: var(--accent);
}

.footer-glyph {
  display: block;
  color: var(--fg);
}
.footer-wordmark:hover .footer-glyph {
  color: var(--accent);
}

.footer-positioning {
  color: var(--fg-2);
  font-size: 0.82rem;
  line-height: 1.5;
  margin: 0;
  max-width: 200px;
}

.footer-theme {
  margin-top: auto;
}

.footer-cols {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--space-6);
}

.footer-col-heading {
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--fg);
  margin: 0 0 var(--space-3);
}

.footer-col ul {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 0.45rem;
}

.footer-col a {
  color: var(--fg-2);
  text-decoration: none;
  transition: color 0.15s ease;
}

.footer-col a:hover {
  color: var(--accent);
}

.footer-meta {
  display: flex;
  align-items: center;
  gap: var(--space-6);
  padding-top: var(--space-5);
  color: var(--fg-3);
  font-size: 0.78rem;
  flex-wrap: wrap;
}

.footer-stack,
.footer-version {
  font-family: var(--f-mono);
}

@media (max-width: 860px) {
  .footer-inner {
    grid-template-columns: 1fr;
  }

  .footer-cols {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 540px) {
  .footer-cols {
    grid-template-columns: 1fr 1fr;
  }

  .footer-meta {
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-2);
  }
}
</style>
