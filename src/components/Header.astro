---
import ThemeToggle from "./ThemeToggle.astro";
const path = Astro.url.pathname;
const active = (href: string) => path === href || path.startsWith(href + "/");

// USMR Phase 5.1l — header route list matches the new-design mock.
// Drops Vision / FAQ / Developers / Docs from the visible nav (those
// routes still resolve when typed). Adds Bridge (→ /platform#bridge
// once Phase 7.4 ships the redirect) and Use cases. Blog aliases
// /writing for now; a /blog → /writing redirect ships in a follow-up.
const NAV_LINKS = [
  { href: "/platform", label: "Platform" },
  { href: "/platform#bridge", label: "Bridge" },
  { href: "/use-cases", label: "Use cases" },
  { href: "/standards", label: "Standards" },
  { href: "/roadmap", label: "Roadmap" },
  { href: "/writing", label: "Blog" },
] as const;
---

<header class="site-nav">
  <div class="container nav">
    <a class="brand" href="/" aria-label="Artagon Home">
      <img
        src="/icons/icon-64.png"
        alt="Artagon"
        width="32"
        height="32"
        style="display:block;"
      />
    </a>
    <nav aria-label="Primary">
      <ul class="links">
        {
          NAV_LINKS.map((link) => (
            <li>
              <a
                href={link.href}
                class={active(link.href) ? "active" : ""}
                aria-current={active(link.href) ? "page" : undefined}
              >
                {link.label}
              </a>
            </li>
          ))
        }
        <li>
          <a href="https://github.com/artagon" rel="noopener noreferrer"
            >GitHub</a
          >
        </li>
      </ul>
    </nav>
    <div class="right">
      <a class="btn nav-cta-ghost" href="/play">Playground</a>
      <a class="btn primary nav-cta-primary" href="/get-started"
        >Request access</a
      >
      <ThemeToggle />
    </div>
  </div>
</header>

<style>
  /* USMR Phase 5.1l — sticky nav with backdrop-filter, per
   * new-design global.css lines 250-261. Tokens consumed via the
   * public alias chain shipped in 5.1h. */
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 30;
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    background: color-mix(in oklab, var(--bg) 72%, transparent);
    border-bottom: 1px solid var(--line-soft);
  }
  .site-nav .nav {
    display: flex;
    align-items: center;
    gap: 32px;
    height: 64px;
  }
  .site-nav .links {
    display: flex;
    gap: 28px;
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: 14px;
    color: var(--fg-1);
  }
  .site-nav .links a {
    padding: 6px 0;
    border-bottom: 1px solid transparent;
    color: inherit;
    text-decoration: none;
    transition:
      border-color 0.2s,
      color 0.2s;
  }
  .site-nav .links a:hover,
  .site-nav .links a.active {
    border-color: var(--accent);
    color: var(--fg);
  }
  .site-nav .right {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .site-nav .right .btn {
    padding: 8px 14px;
    font-size: 13px;
  }
</style>
