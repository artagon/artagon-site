---
import ArtagonGlyph from "./ArtagonGlyph.astro";
import ThemeToggle from "./ThemeToggle.astro";
const path = Astro.url.pathname;
const active = (href: string) => path === href || path.startsWith(href + "/");

// USMR Phase 5.1l — header route list matches the new-design mock.
// Drops Vision / FAQ / Developers / Docs from the visible nav (those
// routes still resolve when typed). Adds Bridge and Use cases. The
// "Blog" label points at /writing (both URLs land on the same
// content via the /blog → /writing 301 redirect added in 5.5).
const NAV_LINKS = [
  { href: "/platform", label: "Platform" },
  { href: "/bridge", label: "Bridge" },
  { href: "/use-cases", label: "Use cases" },
  { href: "/standards", label: "Standards" },
  { href: "/roadmap", label: "Roadmap" },
  { href: "/writing", label: "Blog" },
] as const;
---

<header class="site-nav">
  <div class="container nav">
    <a class="brand site-nav__brand" href="/" aria-label="Artagon Home">
      <ArtagonGlyph class="site-nav__glyph" />
      <span class="site-nav__wordmark">Artagon</span>
    </a>
    <nav aria-label="Primary">
      <ul class="links">
        {
          NAV_LINKS.map((link) => (
            <li>
              <a
                href={link.href}
                class={active(link.href) ? "active" : ""}
                aria-current={active(link.href) ? "page" : undefined}
              >
                {link.label}
              </a>
            </li>
          ))
        }
        <li>
          <a href="https://github.com/artagon" rel="noopener noreferrer"
            >GitHub</a
          >
        </li>
      </ul>
    </nav>
    <div class="right">
      <a class="btn nav-cta-ghost" href="/play">Playground</a>
      <a class="btn primary nav-cta-primary" href="/get-started"
        >Request access</a
      >
      <ThemeToggle />
    </div>
    {/* USMR Phase 5.5.11 — mobile hamburger toggle. Hidden on desktop;
      flex on touch viewports (<720px). Body.nav-open opens the
      panels per the canonical index.html:402-421. */}
    <button
      type="button"
      class="nav-toggle"
      aria-label="Toggle navigation"
      aria-expanded="false"
      aria-controls="primary-nav"
      data-nav-toggle
    >
      <span aria-hidden="true" />
      <span aria-hidden="true" />
      <span aria-hidden="true" />
    </button>
  </div>
</header>

<script>
  // USMR Phase 5.5.11 — bind the hamburger toggle. Toggles
  // body.nav-open + the button's aria-expanded. Non-recurring;
  // safe across HMR re-mounts since we attach via dataset key.
  const toggle = document.querySelector<HTMLButtonElement>("[data-nav-toggle]");
  if (toggle) {
    toggle.addEventListener("click", () => {
      const open = document.body.classList.toggle("nav-open");
      toggle.setAttribute("aria-expanded", open ? "true" : "false");
    });
  }
</script>

<style>
  /* USMR Phase 5.1l — sticky nav with backdrop-filter, per
   * new-design global.css lines 250-261. Tokens consumed via the
   * public alias chain shipped in 5.1h. */
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 30;
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    background: color-mix(in oklab, var(--bg) 72%, transparent);
    border-bottom: 1px solid var(--line-soft);
  }
  .site-nav .nav {
    display: flex;
    align-items: center;
    gap: 32px;
    height: 64px;
  }
  .site-nav .links {
    display: flex;
    gap: 28px;
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: 14px;
    color: var(--fg-1);
  }
  .site-nav .links a {
    padding: 6px 0;
    border-bottom: 1px solid transparent;
    color: inherit;
    text-decoration: none;
    transition:
      border-color 0.2s,
      color 0.2s;
  }
  .site-nav .links a:hover,
  .site-nav .links a.active {
    border-color: var(--accent);
    color: var(--fg);
  }
  .site-nav .right {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .site-nav .right .btn {
    padding: 8px 14px;
    font-size: 13px;
    /* Override the legacy theme.css icon decoration (◆ / ⚡ / ⭐ etc.)
     * for nav-cta buttons — the new-design header keeps the CTAs
     * clean without prefix glyphs. */
  }
  .site-nav .right .btn::before,
  .site-nav .right .btn:hover::before {
    content: none !important;
  }
  /* Force `.btn.primary` to render solid-filled per new-design
   * global.css line 245. The legacy theme.css `.btn` rule paints a
   * translucent-teal background with a faint border, which reads as
   * a "ghost" button — wrong for the primary "Request access" CTA. */
  .site-nav .right .btn.primary {
    background: var(--accent);
    color: var(--accent-ink);
    border-color: transparent;
  }
  .site-nav .right .btn.primary:hover {
    background: color-mix(in oklab, var(--accent) 90%, white);
    color: var(--accent-ink);
    border-color: transparent;
    transform: translateY(-1px);
  }

  .site-nav__brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--fg);
    text-decoration: none;
  }
  .site-nav__wordmark {
    /* Canonical (new-design index.html:550-554): font-family
     * var(--f-sans), font-size 17, weight 500, tracking -0.01em.
     * BaseLayout sets the global default --f-sans = Inter. */
    font-family: var(--f-sans);
    font-size: 17px;
    font-weight: 500;
    letter-spacing: -0.01em;
    color: var(--fg);
    line-height: 1;
  }
  .site-nav__glyph {
    display: block;
    color: var(--fg);
  }

  /* USMR Phase 5.5.11 — canonical hamburger + open-state CSS per
   * new-design/extracted/src/pages/index.html:387-421. Hidden by
   * default; flex on viewports <720px. body.nav-open class is the
   * open-state pivot; the script at the bottom of this component
   * toggles it on click. WCAG 2.5.5 — button is exactly 44×44 CSS px. */
  .nav-toggle {
    display: none;
    width: 44px;
    height: 44px;
    margin-left: auto;
    background: transparent;
    border: 1px solid var(--line);
    border-radius: 8px;
    cursor: pointer;
    align-items: center;
    justify-content: center;
    gap: 4px;
    flex-direction: column;
    padding: 0;
  }
  .nav-toggle span {
    display: block;
    width: 18px;
    height: 1.5px;
    background: var(--fg-1);
    transition:
      transform 0.2s,
      opacity 0.2s;
  }
  .nav-toggle:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  @media (max-width: 719px) {
    .site-nav .nav {
      gap: 16px;
    }
    .site-nav .links,
    .site-nav .right {
      display: none;
    }
    .nav-toggle {
      display: flex;
    }
    /* Open-state — links panel slides in below sticky bar; CTAs
     * dock to the bottom edge as a row.  Use :global(body.nav-open)
     * because the body class is set by the inline <script> at the
     * end of this component, outside Astro's scoped-style hash. */
    :global(body.nav-open) .site-nav .links,
    :global(body.nav-open) .site-nav .right {
      display: flex !important;
      position: fixed;
      left: 0;
      right: 0;
      top: 64px;
      background: var(--bg);
      border-bottom: 1px solid var(--line-soft);
      padding: 24px var(--gutter, 20px);
      flex-direction: column;
      gap: 4px;
      z-index: 29;
    }
    :global(body.nav-open) .site-nav .right {
      top: auto;
      bottom: 0;
      border-top: 1px solid var(--line-soft);
      border-bottom: 0;
      flex-direction: row;
      justify-content: stretch;
    }
    /* Open-state link sizing — bigger tap targets per WCAG 2.5.5. */
    :global(body.nav-open) .site-nav .links a {
      font-size: 18px;
      padding: 12px 0;
      border-bottom: 1px solid var(--line-soft);
    }
    /* Hamburger animation — middle bar fades, top + bottom rotate
     * into an X (canonical index.html:418-420). */
    :global(body.nav-open) .nav-toggle span:nth-child(1) {
      transform: translateY(5px) rotate(45deg);
    }
    :global(body.nav-open) .nav-toggle span:nth-child(2) {
      opacity: 0;
    }
    :global(body.nav-open) .nav-toggle span:nth-child(3) {
      transform: translateY(-5px) rotate(-45deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-toggle span {
      transition: none;
    }
  }
</style>
