---
import type { FaqItem } from '../data/faq';
import { renderMarkdown } from '../lib/markdown';

const item = Astro.props as FaqItem;
const renderedAnswer = await renderMarkdown(item.answer);
---

<details id={item.id} class="faq-item">
  <summary class="faq-question">
    <span class="faq-q-text">{item.question}</span>
    <svg class="faq-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
      <path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </summary>
  <div class="faq-answer">{renderedAnswer}</div>
</details>

<style>
.faq-item {
  background: var(--card-bg);
  border: 1px solid var(--card-stroke);
  border-radius: 12px;
  margin-bottom: 12px;
  scroll-margin-top: 80px;
}

.faq-question {
  cursor: pointer;
  padding: 18px 20px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  font-weight: 600;
  /* USMR Phase 5.5.16-pt124 — rem→px discipline (pt19-22). The
   * 1.05rem at root 16 resolves to 16.8 px; 17 px is the closest
   * canonical fixed-px match. Applies to all FAQ question rows. */
  font-size: 17px;
  color: var(--fg);
  list-style: none;
  user-select: none;
  transition: color 0.2s ease;
}

.faq-question::-webkit-details-marker { display: none; }
.faq-question::marker { content: none; }

.faq-question:hover {
  color: var(--accent);
}

.faq-q-text {
  flex: 1;
}

.faq-icon {
  flex-shrink: 0;
  transition: transform 0.3s ease;
}

details[open] .faq-icon {
  transform: rotate(180deg);
}

.faq-answer {
  padding: 0 20px 20px 20px;
  color: var(--fg-2);
  line-height: 1.7;
  /* USMR Phase 5.5.16-pt124 — rem→px (pt19-22). 0.95rem ≈ 15.2; 15 px
   * keeps the question/answer hierarchy (17 / 15) and aligns with the
   * project's body-copy fixed-px range. */
  font-size: 15px;
}

.faq-answer p {
  margin: 0;
}

.faq-answer p + p {
  margin-top: 12px;
}

.faq-answer ul,
.faq-answer ol {
  margin: 12px 0 0 20px;
  padding: 0;
}

.faq-answer li {
  margin: 6px 0;
}

.faq-answer a {
  color: var(--accent);
  text-decoration: underline;
  text-underline-offset: 2px;
}

.faq-answer a:hover {
  color: var(--accent);
}

@media (max-width: 768px) {
  .faq-question {
    padding: 14px 16px;
    /* USMR Phase 5.5.16-pt124 — rem→px (1rem → 16). */
    font-size: 16px;
  }

  .faq-answer {
    padding: 0 16px 16px 16px;
    /* USMR Phase 5.5.16-pt124 — rem→px (0.9rem ≈ 14.4 → 14). */
    font-size: 14px;
  }
}

/* USMR Phase 5.5.16-pt130 — `prefers-reduced-motion` override per
 * DESIGN.md §8.2 motion principles. The chevron icon rotates 180°
 * when the <details> opens (`details[open] .faq-icon { transform:
 * rotate(180deg) }`). Rotation counts as motion under reduced-motion.
 * Disabling the transition makes the rotation instant — the icon
 * still flips to indicate state, just without the 0.3 s sweep. The
 * .faq-question color transition is also zeroed to keep state
 * changes paint-synchronous. */
@media (prefers-reduced-motion: reduce) {
  .faq-question,
  .faq-icon {
    transition: none;
  }
}

/* USMR Phase 5.5.16-pt126 — forced-colors mode overrides per
 * DESIGN.md §7. The OS palette remap (Windows High Contrast)
 * collapses var(--accent) into a flat system color, so the FAQ
 * question hover affordance + the in-answer link colors lose
 * their signal. Map:
 *   - .faq-question:hover (q-text fg flips to accent)  → Highlight
 *   - .faq-answer a (the in-prose link color)          → LinkText
 *   - .faq-answer a:hover                              → Highlight
 * The default `<a>` underline + 2px text-underline-offset survive
 * the palette remap because they're system-defaults under
 * forced-colors. */
@media (forced-colors: active) {
  .faq-question:hover {
    color: Highlight;
  }
  .faq-answer a {
    color: LinkText;
  }
  .faq-answer a:hover,
  .faq-answer a:focus-visible {
    color: Highlight;
  }
}
</style>
