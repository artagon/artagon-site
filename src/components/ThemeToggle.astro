---
// ThemeToggle.astro — Phase 3.6
// <button> island: toggles between 'midnight' and 'twilight' themes.
// All DOM mutations via setAttribute only (no innerHTML/outerHTML/string-
// concatenated attribute construction) — satisfies no-set-html-directive rule.
---
<button
  type="button"
  class="theme-toggle"
  data-theme-toggle
  aria-pressed="false"
  aria-label="Switch to twilight theme"
>
  <!-- Moon icon — visible when midnight (not pressed) -->
  <svg class="icon-moon" aria-hidden="true" focusable="false" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
  </svg>
  <!-- Sun icon — visible when twilight (pressed) -->
  <svg class="icon-sun" aria-hidden="true" focusable="false" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="12" r="5"/>
    <line x1="12" y1="1" x2="12" y2="3"/>
    <line x1="12" y1="21" x2="12" y2="23"/>
    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
    <line x1="1" y1="12" x2="3" y2="12"/>
    <line x1="21" y1="12" x2="23" y2="12"/>
    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
  </svg>
</button>

<script is:inline>
// Pre-paint aria-sync: runs immediately after the button is parsed (BaseLayout's
// pre-paint has already applied data-theme). Syncs aria-pressed on every instance.
(function(){
  var t = document.documentElement.getAttribute('data-theme');
  var pressed = t === 'twilight';
  var label = pressed ? 'Switch to midnight theme' : 'Switch to twilight theme';
  document.querySelectorAll('[data-theme-toggle]').forEach(function(btn){
    btn.setAttribute('aria-pressed', String(pressed));
    btn.setAttribute('aria-label', label);
  });
})();
</script>

<script>
// ThemeToggle click handler — bundled by Astro (not inline, covered by 'self').
// Allowlist: only 'midnight' and 'twilight' are valid themes.
// All DOM mutations via setAttribute only (no innerHTML / outerHTML).
(function () {
  var KEY = 'artagon.theme';
  var ALLOWED = ['midnight', 'twilight'];
  var DEFAULT = 'twilight';

  function isValid(v: unknown): v is string {
    return typeof v === 'string' && ALLOWED.indexOf(v) >= 0;
  }

  function syncButtons(theme: string) {
    var pressed = theme === 'twilight';
    var label = pressed ? 'Switch to midnight theme' : 'Switch to twilight theme';
    document.querySelectorAll('[data-theme-toggle]').forEach(function(btn) {
      btn.setAttribute('aria-pressed', String(pressed));
      btn.setAttribute('aria-label', label);
    });
  }

  function applyTheme(t: unknown) {
    var theme = isValid(t) ? t : DEFAULT;
    document.documentElement.setAttribute('data-theme', theme);
    try { localStorage.setItem(KEY, theme); } catch (_) {}
    try {
      var bg = getComputedStyle(document.documentElement).getPropertyValue('--bg').trim();
      var meta = document.querySelector('meta[name="theme-color"]');
      if (meta && bg) meta.setAttribute('content', bg);
    } catch (_) {}
    syncButtons(theme);
  }

  document.querySelectorAll('[data-theme-toggle]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var current = document.documentElement.getAttribute('data-theme');
      applyTheme(current === 'twilight' ? 'midnight' : 'twilight');
    });
  });
})();
</script>

<style>
.theme-toggle {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 34px;
  height: 34px;
  border-radius: 8px;
  border: 1px solid var(--line);
  background: transparent;
  color: var(--fg-2);
  cursor: pointer;
  font: inherit;
  transition: color 0.15s ease, border-color 0.15s ease, background 0.15s ease;
}

.theme-toggle:hover {
  color: var(--fg);
  border-color: var(--accent);
  background: color-mix(in srgb, var(--accent) 8%, transparent);
}

.theme-toggle:focus-visible {
  outline: 2px solid var(--accent);
  outline-offset: 2px;
}

/* Show moon icon when midnight (not pressed); show sun when twilight (pressed) */
.theme-toggle .icon-sun { display: none; }
.theme-toggle[aria-pressed="true"] .icon-moon { display: none; }
.theme-toggle[aria-pressed="true"] .icon-sun { display: inline; }
</style>
