---
import Base from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ShimPage from '../../components/ShimPage.astro';
---
{/* USMR Phase 5.5.16-pt144 — extended Base meta description to
    canonical 150-160 char range per DESIGN.md §9.5. */}
<Base title="Developers — Artagon" description="SDKs, APIs, conformance harness, and protocol cookbooks for the Artagon identity platform. Hub launches alongside the design-partner program." robots="noindex, nofollow">
  <Fragment slot="header">
    <Header />
  </Fragment>
  <ShimPage
    title="Developers"
    description="SDKs, APIs, and the conformance harness. Use Docs & Playground while this hub is being built."
    ctaHref="/docs"
    ctaLabel="Open Docs"
    altLinks={[{href:'/play',label:'Open Playground'}]}
  />
  <Fragment slot="footer">
    <Footer />
  </Fragment>
</Base>
