---
import Base from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---
<Base title="Search — Artagon" description="Search the site — Verified. Private. Attested.">
  <Fragment slot="header"><Header /></Fragment>
  {/* USMR Phase 5.5.16-pt119 — same canonical sizing pattern as
      pt117/pt118 — bare <h1>Search</h1> would render at 102 px
      hero size. Scoped to .display + clamp(40, 5vw, 64). */}
  {/* USMR Phase 5.5.16-pt138 — was <main class="search-page">; now
      <div> to avoid nesting inside BaseLayout's <main id="main-
      content">. Scoped CSS targets .search-page* unchanged. */}
  <div class="search-page">
    <h1 class="search-page__title display">Search</h1>
    <div class="search-page__box">
      <div id="docsearch"></div>
      <div id="docsearch-fallback" class="card search-page__fallback">
        <strong>Site search not configured.</strong><br/>
        Add your DocSearch keys to <code>/docsearch.json</code> to enable instant search.
      </div>
    </div>
    {/* USMR Phase 5.5.16-pt140 — landmark labelling + aria-live for
        result-list updates. DocSearch populates results into this
        container; AT users get a polite announcement when the list
        changes. */}
    <section id="results" class="search-page__results" aria-label="Search results" aria-live="polite"></section>
  </div>

  <style>
    .search-page {
      max-width: var(--maxw, 1240px);
      margin: clamp(48px, 8vw, 80px) auto 0;
      padding-inline: clamp(24px, 4vw, 40px);
      padding-bottom: clamp(48px, 8vw, 80px);
    }
    .search-page__title {
      font-size: clamp(40px, 5vw, 64px);
      line-height: 1.05;
      margin: 0 0 16px;
    }
    .search-page__box {
      margin-top: 10px;
    }
    .search-page__fallback {
      margin-top: 12px;
      display: none;
    }
    .search-page__results {
      margin-top: 20px;
    }
  </style>
  <script src="https://cdn.jsdelivr.net/npm/@docsearch/js@3"></script>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@docsearch/css@3" />
  <script>
  (async function(){
    try{
      const res = await fetch('/docsearch.json', {cache:'no-store'});
      if(!res.ok) throw new Error('docsearch.json missing');
      const cfg = await res.json();
      if(!cfg.appId || !cfg.apiKey || !cfg.indexName){ document.getElementById('docsearch-fallback').style.display='block'; return; }
      // @ts-ignore
      docsearch({ container:'#docsearch', appId: cfg.appId, apiKey: cfg.apiKey, indexName: cfg.indexName });
    }catch(e){ document.getElementById('docsearch-fallback').style.display='block'; }
  })();
  </script>
  <Fragment slot="footer"><Footer /></Fragment>
</Base>
