---
// USMR Phase 5.5.1 — /platform route. Mounts the PillarsIsland
// directly per the canonical new-design/extracted/src/pages/platform.html
// (line 848: `<App><Pillars/></App>` — no separate page hero). The
// island ports Pillars.jsx's internal hero ("Platform" eyebrow +
// "Three pillars, one coherent platform." h2), so any page-level
// hero here would duplicate that header.
//
// 5.2.5 originally shipped a `platform-hero` section + a
// `<section id="bridge">` anchor (the 5.1q.4 stub from when /bridge
// didn't resolve). Both dropped in 5.5.1: the page hero duplicated
// the island's own header, and /bridge now exists as a real route
// (5.2.8) so the anchor stub is no longer needed.
import Base from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PillarsIsland from '../../components/PillarsIsland.tsx';
---
<Base
  title="Platform — Artagon"
  description="Three pillars, one coherent platform — high-assurance authentication, verifiable credentials, and graph-native authorization unified under one runtime."
  path="/platform"
>
  <Fragment slot="header"><Header /></Fragment>

  <main id="main">
    <PillarsIsland client:visible />
  </main>

  <Fragment slot="footer"><Footer /></Fragment>
</Base>
