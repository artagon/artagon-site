---
// USMR Phase 5.2.8 — /bridge route. Standalone page for the
// OID4VP→OIDC bridge story (was previously a 301 redirect to
// /platform/#bridge per 5.1q.3 — the redirect drops as part of
// this phase since /bridge now resolves directly).
//
// The page mounts <BridgeFlow client:visible /> which ports the
// new-design Bridge.jsx composition: 3-party board + 4-step strip
// with auto-cycle + click-to-commit. The /platform `<section
// id="bridge">` from 5.1q.4 stays in place for backwards
// compatibility with external links to /platform#bridge.
import { getEntry } from 'astro:content';
import Base from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BridgeFlow from '../../components/BridgeFlow.tsx';

const platform = await getEntry('pages', 'platform');
if (!platform?.data.bridge?.sentence) {
  throw new Error(
    "platform.mdx frontmatter `bridge.sentence` missing — /bridge consumes the canonical bridge sentence shipped via 5.1q.4."
  );
}
const bridgeSentence = platform.data.bridge.sentence;
---
<Base
  title="Bridge — Artagon"
  description="The OID4VP→OIDC bridge: legacy OIDC apps consume verifiable credentials from a user's wallet without a rewrite."
  path="/bridge"
>
  <Fragment slot="header"><Header /></Fragment>

  <main id="main">
    <section class="bridge-intro container" aria-labelledby="bridge-intro-h">
      <p class="bridge-intro__eyebrow">Bridge</p>
      <h1 id="bridge-intro-h" class="bridge-intro__title display">
        From <em class="bridge-intro__emphasis">OIDC</em> to verifiable credentials — without a rewrite.
      </h1>
      <p class="bridge-intro__sentence">{bridgeSentence}</p>
    </section>

    <BridgeFlow client:visible />
  </main>

  <Fragment slot="footer"><Footer /></Fragment>
</Base>

<style>
  .bridge-intro {
    padding-block: clamp(64px, 10vw, 120px) clamp(48px, 6vw, 80px);
    max-width: var(--maxw, 1240px);
    margin-inline: auto;
    padding-inline: clamp(24px, 4vw, 40px);
  }
  .bridge-intro__eyebrow {
    font-family: var(--f-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--fg-3);
    margin: 0 0 0.75rem;
  }
  .bridge-intro__title {
    font-family: var(--f-display);
    font-size: clamp(2.4rem, 5vw, 4rem);
    line-height: 1.1;
    letter-spacing: var(--display-tracking, -0.02em);
    font-weight: var(--display-weight, 500);
    color: var(--fg);
    margin: 0 0 clamp(1rem, 2vw, 1.5rem);
    max-width: 22ch;
  }
  .bridge-intro__emphasis {
    font-family: var(--f-emphasis, var(--f-serif));
    font-style: italic;
  }
  .bridge-intro__sentence {
    color: var(--fg-1);
    font-size: clamp(1rem, 1.2vw, 1.15rem);
    line-height: 1.55;
    max-width: 60ch;
    margin: 0;
  }
</style>
