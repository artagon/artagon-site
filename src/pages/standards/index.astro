---
// USMR Phase 5.1q.2 — minimal /standards route. Sources copy from
// src/content/pages/standards.mdx; full registry-driven sections + TOC
// anchor list land in Phase 5.4 and consume `src/data/standards.ts`.
//
// Page scaffolding lives in src/layouts/PageLayout.astro.
import { getEntry } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';

const entry = await getEntry('pages', 'standards');
if (!entry) {
  throw new Error(
    "standards.mdx missing — Phase 5.1q.2 expects src/content/pages/standards.mdx to exist."
  );
}
---
<PageLayout entry={entry} path="/standards" />
