---
import { getEntry } from "astro:content";
import Base from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Tagline from "../components/Tagline.astro";
import MissionSection from "../components/MissionSection.astro";
import HeroChart from "../components/HeroChart.astro";
import { ORG } from "../data/organization";

// USMR Phase 5.1a — hero now reads from src/content/pages/home.mdx so
// content edits don't require .astro changes. The remaining sections
// (pillar grid, mission, developers, FAQ, etc.) keep their existing
// markup until Phase 5.x decomposes them into typed registries.
const home = await getEntry("pages", "home");
if (!home) throw new Error("home.mdx content entry not found");
const { eyebrow, headline, lede, ctas, title, description, onRamp } = home.data;
---

<Base title={title} description={description}>
  <Fragment slot="header"><Header /></Fragment>

  <section class="hero container">
    <div class="twocol">
      <div>
        <p class="hero__eyebrow">{eyebrow}</p>
        <h1 id="hero-h1">{headline}</h1>
        <p id="hero-sub" class="sub">{lede}</p>
        <div style="margin-top:6px"><Tagline /></div>
        {
          ctas.length > 0 && (
            <div class="actions">
              {ctas.map((cta) => (
                <a
                  class={`btn ${cta.variant === "primary" ? "primary" : ""}`}
                  href={cta.href}
                  rel={cta.rel}
                >
                  {cta.label}
                </a>
              ))}
            </div>
          )
        }
        <div class="badges" style="margin-top:14px">
          <span class="pill">OIDC 2.1 + PAR/JAR/JARM/DPoP/mTLS</span>
          <span class="pill">GNAP with PoP + continuation</span>
          <span class="pill">SD-JWT & BBS+ VCs</span>
          <span class="pill">Zanzibar graph + PDP</span>
        </div>
      </div>
      <div class="hero-art">
        <HeroChart
          data={[12,18,14,22,28,19,31,27,34]}
          width={620}
          height={360}
          label="Verified claims & policy decisions trend"
        />
      </div>
    </div>

    <div class="kpi" aria-label="Key performance indicators">
      <div class="card">
        <div class="eyebrow">Decision latency</div><h4>&lt; 10 ms p95</h4><div
          class="discrete"
        >
          Policy + graph
        </div>
      </div>
      <div class="card">
        <div class="eyebrow">Token issuance</div><h4>&lt; 120 ms p95</h4><div
          class="discrete"
        >
          DPoP / mTLS bound
        </div>
      </div>
      <div class="card">
        <div class="eyebrow">VC verification</div><h4>&lt; 150 ms p95</h4><div
          class="discrete"
        >
          SD-JWT & BBS+
        </div>
      </div>
      <div class="card">
        <div class="eyebrow">Availability</div><h4>99.95%</h4><div
          class="discrete"
        >
          Multi-region
        </div>
      </div>
    </div>
  </section>

  <section id="platform" class="section">
    <div class="container">
      <div class="grid cols-3">
        <div class="card">
          <div class="eyebrow">Unified OP / AS</div><h3>OIDC 2.1 + GNAP</h3><p>
            Hardened OAuth profiles (PAR · JAR/JARM · RAR · DPoP · mTLS), GNAP
            PoP & continuation, client key rotation.
          </p>
        </div>
        <div class="card">
          <div class="eyebrow">Verifiable Identity</div><h3>
            Selective disclosure
          </h3><p>
            Issue SD‑JWT & BBS+ VCs, verify via OID4VCI/VP, unlinkable
            presentations, revocation with StatusList2021 and Merkle proofs.
          </p>
        </div>
        <div class="card">
          <div class="eyebrow">Policy & Graph</div><h3>
            Zanzibar‑style checks
          </h3><p>
            Relationship graph as fast path with PDP overlays (XACML · Cedar ·
            OPA), obligations for redaction, masking, quotas, and consent.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section id="how" class="section">
    <div class="container twocol">
      <div>
        <h2>How it works</h2>
        <div class="card" aria-label="Flow">
          <pre
            class="code"><code>1. Authenticate with passkey (FIDO2/WebAuthn)
2. Present minimal claims (OID4VP + SD‑JWT/BBS+)
3. Graph check + policy overlay → DPoP/mTLS‑bound token</code></pre>
        </div>
      </div>
      <div class="grid">
        <div class="card">
          <div class="eyebrow">Attestation</div><strong
            >Android Play Integrity · Apple App Attest · WebAuthn</strong
          ><br />Evidence-bound clients with rotation and per-device DPoP
          binding.
        </div>
        <div class="card">
          <div class="eyebrow">Proofing</div><strong
            >NIST 800‑63 / eIDAS mapping</strong
          ><br />Pluggable doc/biometric KYC → Proofing VC for onboarding &
          step‑up.
        </div>
      </div>
    </div>
  </section>

  <MissionSection />

  <section id="developers" class="section">
    <div class="container twocol">
      <div>
        <h2>For developers</h2>
        <p>
          SDKs for Java · Rust · JS/TS · Go · Swift, GraphQL + REST APIs, and a
          conformance harness. Spin up a sandbox tenant in minutes and test
          OIDC, GNAP, and VC flows with real tokens.
        </p>
        <div class="actions">
          <a class="btn" href="/docs">Browse APIs</a>
          <a class="btn" href="/play">Open Playground</a>
          <a class="btn" href="https://github.com/artagon" rel="noopener"
            >GitHub</a
          >
        </div>
      </div>
      <div class="card" aria-label="Quickstart">
        <div class="eyebrow">Quickstart (OIDC + DPoP)</div>
        <pre
          class="code"><code>curl -X POST $TOKEN_ENDPOINT \
 -H "DPoP: &lt;jwt&gt;" -H "Content-Type: application/x-www-form-urlencoded" \
 -d "grant_type=authorization_code&amp;code=..."</code></pre>
        <div class="discrete">
          Use our SDKs to generate DPoP and handle key rotation automatically.
        </div>
      </div>
    </div>
  </section>

  <section id="faq" class="section">
    <div class="container">
      <h2>Frequently asked questions</h2>
      <details>
        <summary>What is the Artagon Identity Platform?</summary><p>
          Artagon combines an OIDC 2.1/OpenID Provider, a GNAP Authorization
          Server, verifiable credentials, device/app attestation, and
          Zanzibar‑style policy in one platform.
        </p>
      </details>
      <details>
        <summary>Does Artagon support OIDC 2.1 and GNAP?</summary><p>
          Yes—OIDC 2.1 with hardened OAuth (PAR · JAR/JARM · RAR · DPoP · mTLS)
          and GNAP with proof‑of‑possession and continuation handles.
        </p>
      </details>
      <details>
        <summary>Do you support passkeys and verifiable credentials?</summary><p
        >
          Yes—passkey/WebAuthn is primary auth, and we issue/verify SD‑JWT &
          BBS+ VCs via OID4VCI/OID4VP.
        </p>
      </details>
      <details>
        <summary>How does authorization work?</summary><p>
          A Zanzibar graph powers fast relationship checks while policies in
          XACML, Cedar, or OPA apply fine‑grained controls and obligations.
        </p>
      </details>
    </div>
  </section>

  {
    onRamp && (
      <section class="onramp section" id="get-started">
        <div class="container">
          <div class="onramp__card">
            <div class="onramp__strip">
              <span>{onRamp.programLabel}</span>
              <span>{onRamp.statusLabel}</span>
            </div>
            <div class="onramp__grid">
              <div class="onramp__lead">
                <h2 class="onramp__headline">{onRamp.headline}</h2>
                <p class="onramp__lede">{onRamp.lede}</p>
                {onRamp.ctas.length > 0 && (
                  <div class="actions">
                    {onRamp.ctas.map((c) => (
                      <a
                        class={`btn ${c.variant === "primary" ? "primary" : ""}`}
                        href={c.href}
                        rel={c.rel}
                      >
                        {c.label}
                      </a>
                    ))}
                  </div>
                )}
              </div>
              <aside class="onramp__contacts" aria-label={onRamp.contactsTitle}>
                <div class="onramp__contacts-title">{onRamp.contactsTitle}</div>
                <dl class="onramp__rows">
                  {ORG.contacts.map((r) => (
                    <div class="onramp__row">
                      <dt>{r.label}</dt>
                      <dd>{r.value}</dd>
                    </div>
                  ))}
                </dl>
                {ORG.contactFootnote && (
                  <p class="onramp__footnote">{ORG.contactFootnote}</p>
                )}
              </aside>
            </div>
          </div>
        </div>
      </section>
    )
  }

  <Fragment slot="footer"><Footer /></Fragment>
</Base>

<style>
  .onramp {
    padding-block: var(--space-12);
  }
  .onramp__card {
    position: relative;
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: clamp(2rem, 4vw, 4.5rem) clamp(1.25rem, 3vw, 4rem);
    background: linear-gradient(135deg, var(--bg-alt) 0%, var(--bg) 80%);
    overflow: hidden;
  }
  .onramp__strip {
    position: absolute;
    top: 1rem;
    left: 1.25rem;
    right: 1.25rem;
    display: flex;
    justify-content: space-between;
    font-family: ui-monospace, Menlo, Consolas, monospace;
    font-size: var(--fs-micro);
    color: var(--muted);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .onramp__grid {
    display: grid;
    gap: clamp(1.5rem, 3vw, 3rem);
    grid-template-columns: minmax(0, 1.6fr) minmax(0, 1fr);
    margin-top: 2rem;
  }
  @media (max-width: 768px) {
    .onramp__grid {
      grid-template-columns: 1fr;
    }
  }
  .onramp__headline {
    font-size: var(--fs-h2);
    line-height: 1.05;
    margin: 0 0 1.5rem;
  }
  .onramp__lede {
    margin: 0 0 2rem;
    max-width: 52ch;
    color: var(--muted);
  }
  .onramp__contacts {
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.75rem;
    background: var(--bg-alt);
    font-family: ui-monospace, Menlo, Consolas, monospace;
    font-size: var(--fs-small);
  }
  .onramp__contacts-title {
    font-size: var(--fs-micro);
    color: var(--muted);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: 0.875rem;
  }
  .onramp__rows {
    margin: 0;
    display: grid;
    gap: 0.5rem;
  }
  .onramp__row {
    display: grid;
    grid-template-columns: minmax(0, 0.6fr) minmax(0, 1fr);
    gap: 1rem;
  }
  .onramp__row dt {
    color: var(--muted);
    margin: 0;
  }
  .onramp__row dd {
    color: var(--text);
    margin: 0;
  }
  .onramp__footnote {
    margin: 0.875rem 0 0;
    color: var(--muted);
    font-size: var(--fs-micro);
    line-height: 1.5;
  }
</style>
