---
import { getCollection, getEntry } from "astro:content";
import Base from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import TrustChainIsland from "../components/TrustChainIsland";
import { AFFILIATIONS, HERO_SPECS } from "../data/affiliations";
import { ORG } from "../data/organization";
import HomeExplore from "../components/HomeExplore.astro";

// USMR Phase 5.1a — hero now reads from src/content/pages/home.mdx so
// content edits don't require .astro changes. The remaining sections
// (pillar grid, mission, developers, FAQ, etc.) keep their existing
// markup until Phase 5.x decomposes them into typed registries.
const home = await getEntry("pages", "home");
if (!home) throw new Error("home.mdx content entry not found");
const { eyebrow, headline, lede, ctas, title, description, onRamp } = home.data;

// USMR Phase 5.1f — latest writing strip. Top N non-draft posts by
// published desc; render the strip only when there's at least one post.
const latestPosts = (await getCollection("writing"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.published.getTime() - a.data.published.getTime())
  .slice(0, 3);

const dateFmt = new Intl.DateTimeFormat("en", {
  year: "numeric",
  month: "short",
  day: "numeric",
});

// USMR Phase 5.1j — eyebrow renders inside a .glow-tag pill. Splitting on
// `&` lets the home.mdx string drive a serif-italic ampersand via the
// `.glow-amp` primitive without authoring HTML in the MDX. Even-index
// segments are plain text; odd-index slots get a single `<em>&</em>`.
const eyebrowSegments = eyebrow.split(/\s*&\s*/);

// USMR Phase 5.1j — headline stacks per the new-design mock. Splits the
// frontmatter "Verified. Private. Attested." string on sentence
// boundaries so each clause renders on its own visual line.
const headlineLines = headline.includes(". ")
  ? headline
      .split(/\.\s+/)
      .filter(Boolean)
      .map((s) => (s.endsWith(".") ? s : `${s}.`))
  : [headline];

// USMR Phase 5.5.5 — onRamp.headline serif-italic emphasis. Splits on
// `*marker*` so authors can wrap a single word in fraunces italic
// (canonical Cta.jsx:27-29 — "Build with the <span class='serif italic'>
// next</span><br/>generation of identity."). Even-index segments are
// plain text; odd-index segments render as `<em class="serif">`.
const onRampHeadlineSegments = onRamp ? onRamp.headline.split(/\*([^*]+)\*/) : [];

// USMR Phase 5.5.13 — Hero lede 3-clause emphasis. Splits on
// `**bold**` so the three keystone words (proven / bound /
// traceable) render in `<b class="hero__lede-emphasis">` per
// canonical Hero.jsx:159-164. Even-index segments plain text;
// odd-index segments are the bold keystones (var(--fg) at 500).
const heroLedeSegments = lede.split(/\*\*([^*]+)\*\*/);
---

<Base title={title} description={description}>
  <Fragment slot="header"><Header /></Fragment>

  <section class="hero container">
    {/* USMR Phase 5.5.5 — meta-strip moved INSIDE the hero section per
     * canonical Hero.jsx:124-141 (single `<div.wrap>` holds the strip
     * + headline grid). Was previously its own `<div class="container">`
     * above the section, which created a visible top-margin gap and
     * decoupled the strip from the hero card. */}
    <div class="hero__meta-strip">
      <span class="hero__meta-strip-tag">v0.9 · Design Partner Preview</span>
      <span class="hero__meta-strip-specs">
        {
          HERO_SPECS.map((spec, i) => (
            <Fragment>
              {i > 0 && <span class="hero__meta-strip-sep" aria-hidden="true">·</span>}
              <a
                href={spec.href}
                target="_blank"
                rel="noopener noreferrer"
                title={spec.title}
                class="hero__meta-strip-link"
              >
                {spec.label}
              </a>
            </Fragment>
          ))
        }
      </span>
      <span class="hero__meta-strip-loc">US — Philadelphia, PA</span>
    </div>

    <div class="twocol">
      <div>
        <span class="hero__eyebrow-tag glow-tag">
          <span class="glow-dot" />
          <span class="glow-text">
            {
              eyebrowSegments.map((seg, i) =>
                i === 0 ? (
                  <Fragment>{seg}</Fragment>
                ) : (
                  <Fragment>
                    <em class="glow-amp">&amp;</em>
                    {seg}
                  </Fragment>
                ),
              )
            }
          </span>
        </span>
        <h1 id="hero-h1" class="display">
          {
            headlineLines.map((line, i) => (
              <Fragment>
                {i > 0 && <br />}
                {line}
              </Fragment>
            ))
          }
        </h1>
        <p id="hero-sub" class="lead">
          {heroLedeSegments.map((segment, i) =>
            i % 2 === 1 ? (
              <b class="hero__lede-emphasis">{segment}</b>
            ) : (
              segment
            )
          )}
        </p>
        {
          ctas.length > 0 && (
            <div class="actions">
              {ctas.map((cta) => (
                <a
                  class={`btn ${cta.variant === "primary" ? "primary" : ""}`}
                  href={cta.href}
                  rel={cta.rel}
                >
                  {cta.label}
                  {cta.variant === "primary" && (
                    <span class="arr" aria-hidden="true">→</span>
                  )}
                </a>
              ))}
            </div>
          )
        }
        <div class="hero__affiliations">
          <div class="hero__affiliations-label">Implements & contributes to</div>
          <div class="hero__affiliations-row">
            {
              AFFILIATIONS.map((aff) => (
                <a
                  href={aff.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  title={aff.title}
                  class="hero__affiliations-link"
                >
                  {aff.label}
                </a>
              ))
            }
          </div>
        </div>
      </div>
      <div class="hero-art">
        <TrustChainIsland client:visible />
      </div>
    </div>

  </section>

  {
    latestPosts.length > 0 && (
      <section class="writing-strip section" id="writing">
        <div class="container">
          <header class="writing-strip__head">
            <h2>Field notes from the team building Artagon.</h2>
            <a class="writing-strip__more" href="/writing">All writing →</a>
          </header>
          <ul role="list" class="writing-strip__list">
            {latestPosts.map((post) => (
              <li class="writing-strip__item">
                <a class="writing-strip__link" href={`/writing/${post.id}`}>
                  <time
                    class="writing-strip__date"
                    datetime={post.data.published.toISOString()}
                  >
                    {dateFmt.format(post.data.published)}
                  </time>
                  <h3 class="writing-strip__title">{post.data.headline}</h3>
                  <p class="writing-strip__lede">{post.data.lede}</p>
                  <span class="writing-strip__cta">Read →</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )
  }

  <HomeExplore />

  {
    onRamp && (
      <section class="onramp section" id="get-started">
        <div class="container">
          <div class="onramp__card">
            <div class="onramp__strip">
              <span>{onRamp.programLabel}</span>
              <span>{onRamp.statusLabel}</span>
            </div>
            <div class="onramp__grid">
              <div class="onramp__lead">
                <h2 class="onramp__headline">
                  {onRampHeadlineSegments.map((segment, i) =>
                    i % 2 === 1 ? (
                      <em class="onramp__headline-emphasis serif">{segment}</em>
                    ) : (
                      segment
                    )
                  )}
                </h2>
                <p class="onramp__lede">{onRamp.lede}</p>
                {onRamp.ctas.length > 0 && (
                  <div class="actions">
                    {onRamp.ctas.map((c) => {
                      const isExternal = c.href.startsWith("http");
                      return (
                        <a
                          class={`btn ${c.variant === "primary" ? "primary" : ""}`}
                          href={c.href}
                          rel={isExternal ? "noopener noreferrer" : c.rel}
                          {...(isExternal ? { target: "_blank" } : {})}
                        >
                          {c.label}
                          {c.variant === "primary" && (
                            <span class="arr" aria-hidden="true">→</span>
                          )}
                          {isExternal && (
                            <span class="sr-only"> (opens in new tab)</span>
                          )}
                        </a>
                      );
                    })}
                  </div>
                )}
              </div>
              <aside class="onramp__contacts" aria-label={onRamp.contactsTitle}>
                <div class="onramp__contacts-title">{onRamp.contactsTitle}</div>
                <dl class="onramp__rows">
                  {ORG.contacts.map((r) => (
                    <div class="onramp__row">
                      <dt>{r.label}</dt>
                      <dd>{r.value}</dd>
                    </div>
                  ))}
                </dl>
                {ORG.contactFootnote && (
                  <p class="onramp__footnote">{ORG.contactFootnote}</p>
                )}
              </aside>
            </div>
          </div>
        </div>
      </section>
    )
  }

  <Fragment slot="footer"><Footer /></Fragment>
</Base>

<style>
  /* USMR Phase 5.1k — hero meta-strip (above hero) + affiliations
   * ticker (below hero CTAs). Both render only on home `/`. */
  .hero__meta-strip {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    margin-bottom: 56px;
    padding-block: 1rem;
    font-family: var(--f-mono);
    font-size: 12px;
    color: var(--fg-2);
    letter-spacing: 0.04em;
    flex-wrap: wrap;
  }
  .hero__meta-strip-tag,
  .hero__meta-strip-loc {
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .hero__meta-strip-loc {
    color: var(--fg-3);
  }
  .hero__meta-strip-specs {
    display: flex;
    gap: 14px;
    align-items: center;
    flex-wrap: wrap;
  }
  .hero__meta-strip-sep {
    color: var(--fg-3);
  }
  .hero__meta-strip-link {
    color: var(--fg);
    font-weight: 500;
    border-bottom: 1px dotted var(--fg-3);
    padding-bottom: 1px;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .hero__meta-strip-link:hover {
    color: var(--accent);
  }

  /* USMR Phase 5.5.13 — Hero lede 3-clause keystones (canonical
   * Hero.jsx:160 — color: var(--fg), font-weight: 500). The keystones
   * (proven / bound / traceable) render as bold spans inside the
   * `.lead` paragraph; the surrounding text uses the lead color. */
  .hero__lede-emphasis {
    color: var(--fg);
    font-weight: 500;
  }

  .hero__affiliations {
    margin-top: 72px;
    padding-top: 28px;
    border-top: 1px solid var(--line-soft);
  }
  .hero__affiliations-label {
    font-family: var(--f-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    color: var(--fg-3);
    text-transform: uppercase;
    margin-bottom: 18px;
  }
  .hero__affiliations-row {
    display: flex;
    flex-wrap: wrap;
    gap: 28px;
    align-items: center;
    font-family: var(--f-mono);
    font-size: 13px;
  }
  .hero__affiliations-link {
    color: var(--fg-1);
    border-bottom: 1px dotted var(--fg-3);
    padding-bottom: 1px;
    opacity: 0.9;
    text-decoration: none;
    transition:
      color 0.2s ease,
      opacity 0.2s ease;
  }
  .hero__affiliations-link:hover {
    color: var(--accent);
    opacity: 1;
  }

  /* USMR Phase 5.1j — hero typography matches new-design global.css
   * (h1 clamp 56-108px, line-height 0.94, letter-spacing -0.035em).
   * Overrides the legacy .hero h1 rule in public/assets/theme.css. */
  .hero__eyebrow-tag {
    margin-bottom: 28px;
  }
  .hero h1.display {
    font-size: clamp(3.5rem, 7.2vw, 6.75rem);
    line-height: 0.94;
    letter-spacing: -0.035em;
    font-weight: 400;
    margin: 0 0 32px;
    font-family: var(--f-display, "Space Grotesk", "Inter Tight", sans-serif);
  }
  .hero h1.display br + * {
    display: inline;
  }

  .onramp {
    padding-block: var(--space-12);
  }
  .onramp__card {
    position: relative;
    border: 1px solid var(--line);
    border-radius: 16px;
    padding: clamp(2rem, 4vw, 4.5rem) clamp(1.25rem, 3vw, 4rem);
    background: linear-gradient(135deg, var(--bg-1) 0%, var(--bg) 80%);
    overflow: hidden;
  }
  .onramp__strip {
    position: absolute;
    top: 1rem;
    left: 1.25rem;
    right: 1.25rem;
    display: flex;
    justify-content: space-between;
    font-family: var(--f-mono);
    font-size: var(--fs-micro);
    color: var(--fg-2);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  /* Canonical Cta.jsx:23-28 — `gridTemplateColumns:'1.2fr 1fr'`. The
   * 1.6fr was an off-canonical inflation that left too little room for
   * the contact card on wide viewports. */
  .onramp__grid {
    display: grid;
    gap: clamp(1.5rem, 3vw, 3rem);
    grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr);
    margin-top: 2rem;
  }
  @media (max-width: 768px) {
    .onramp__grid {
      grid-template-columns: 1fr;
    }
  }
  .onramp__headline {
    font-size: var(--fs-h2);
    line-height: 1.05;
    margin: 0 0 1.5rem;
  }
  /* Canonical Cta.jsx:136-137 — italic Fraunces emphasis on the
   * marker-split word ("next"). The visible italic was missing because
   * this rule was absent. `--f-emphasis` falls back to `--f-serif`
   * (Fraunces) per the hero-font matrix. */
  .onramp__headline-emphasis {
    font-family: var(--f-emphasis, var(--f-serif));
    font-style: italic;
    font-weight: 400;
  }
  .onramp__lede {
    margin: 0 0 2rem;
    max-width: 52ch;
    color: var(--fg-2);
  }
  .onramp__contacts {
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 1.75rem;
    background: var(--bg-1);
    font-family: var(--f-mono);
    font-size: var(--fs-small);
  }
  /* Canonical contact card colors — Cta.jsx:46,56,60-61. Title sits at
   * fg-3 (deep label), `dt` at fg-3, `dd` at fg-1 (mono value),
   * footnote at fg-3. Pre-canonical fg-2/fg/fg-2 made labels read as
   * primary text. */
  .onramp__contacts-title {
    font-size: var(--fs-micro);
    color: var(--fg-3);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: 0.875rem;
  }
  .onramp__rows {
    margin: 0;
    display: grid;
    gap: 0.5rem;
  }
  .onramp__row {
    display: grid;
    grid-template-columns: minmax(0, 0.6fr) minmax(0, 1fr);
    gap: 1rem;
  }
  .onramp__row dt {
    color: var(--fg-3);
    margin: 0;
  }
  .onramp__row dd {
    color: var(--fg-1);
    margin: 0;
  }
  .onramp__footnote {
    margin: 0.875rem 0 0;
    color: var(--fg-3);
    font-size: var(--fs-micro);
    line-height: 1.5;
  }

  /* USMR Phase 5.1f — latest writing strip */
  .writing-strip {
    padding-block: var(--space-12);
  }
  .writing-strip__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-6);
    margin-block-end: var(--space-8);
    flex-wrap: wrap;
  }
  .writing-strip__head h2 {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    line-height: 1.15;
    margin: 0;
    max-width: 28ch;
  }
  .writing-strip__more {
    font-family: var(--f-mono);
    font-size: 0.875rem;
    color: var(--accent);
    text-decoration: none;
    white-space: nowrap;
  }
  .writing-strip__more:hover,
  .writing-strip__more:focus-visible {
    text-decoration: underline;
  }
  .writing-strip__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--space-6);
    grid-template-columns: repeat(3, 1fr);
  }
  @media (max-width: 900px) {
    .writing-strip__list {
      grid-template-columns: 1fr;
    }
  }
  .writing-strip__link {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    height: 100%;
    padding: var(--space-6);
    border: 1px solid var(--line);
    border-radius: 12px;
    color: inherit;
    text-decoration: none;
    background: var(--bg-1);
    transition:
      border-color 0.15s ease,
      transform 0.15s ease;
  }
  .writing-strip__link:hover,
  .writing-strip__link:focus-visible {
    border-color: var(--accent);
    transform: translateY(-2px);
  }
  .writing-strip__date {
    font-family: var(--f-mono);
    font-size: var(--fs-micro);
    color: var(--fg-2);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .writing-strip__title {
    font-size: 1.25rem;
    line-height: 1.25;
    margin: 0;
  }
  .writing-strip__lede {
    color: var(--fg-2);
    line-height: 1.55;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .writing-strip__cta {
    margin-top: auto;
    font-family: var(--f-mono);
    font-size: var(--fs-micro);
    color: var(--accent);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
</style>
