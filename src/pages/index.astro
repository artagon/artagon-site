---
import { getCollection, getEntry } from "astro:content";
import Base from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import MissionSection from "../components/MissionSection.astro";
import TrustChainIsland from "../components/TrustChainIsland";
import { ORG } from "../data/organization";
import { PILLARS } from "../data/pillars";

// USMR Phase 5.1a — hero now reads from src/content/pages/home.mdx so
// content edits don't require .astro changes. The remaining sections
// (pillar grid, mission, developers, FAQ, etc.) keep their existing
// markup until Phase 5.x decomposes them into typed registries.
const home = await getEntry("pages", "home");
if (!home) throw new Error("home.mdx content entry not found");
const { eyebrow, headline, lede, ctas, title, description, onRamp } = home.data;

// USMR Phase 5.1f — latest writing strip. Top N non-draft posts by
// published desc; render the strip only when there's at least one post.
const latestPosts = (await getCollection("writing"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.published.getTime() - a.data.published.getTime())
  .slice(0, 3);

const dateFmt = new Intl.DateTimeFormat("en", {
  year: "numeric",
  month: "short",
  day: "numeric",
});

// USMR Phase 5.1j — eyebrow renders inside a .glow-tag pill. Splitting on
// `&` lets the home.mdx string drive a serif-italic ampersand via the
// `.glow-amp` primitive without authoring HTML in the MDX. Even-index
// segments are plain text; odd-index slots get a single `<em>&</em>`.
const eyebrowSegments = eyebrow.split(/\s*&\s*/);

// USMR Phase 5.1j — headline stacks per the new-design mock. Splits the
// frontmatter "Verified. Private. Attested." string on sentence
// boundaries so each clause renders on its own visual line.
const headlineLines = headline.includes(". ")
  ? headline
      .split(/\.\s+/)
      .filter(Boolean)
      .map((s) => (s.endsWith(".") ? s : `${s}.`))
  : [headline];
---

<Base title={title} description={description}>
  <Fragment slot="header"><Header /></Fragment>

  <section class="hero container">
    <div class="twocol">
      <div>
        <span class="hero__eyebrow-tag glow-tag">
          <span class="glow-dot" />
          <span class="glow-text">
            {
              eyebrowSegments.map((seg, i) =>
                i === 0 ? (
                  <Fragment>{seg}</Fragment>
                ) : (
                  <Fragment>
                    <em class="glow-amp">&amp;</em>
                    {seg}
                  </Fragment>
                ),
              )
            }
          </span>
        </span>
        <h1 id="hero-h1" class="display">
          {
            headlineLines.map((line, i) => (
              <Fragment>
                {i > 0 && <br />}
                {line}
              </Fragment>
            ))
          }
        </h1>
        <p id="hero-sub" class="sub">{lede}</p>
        {
          ctas.length > 0 && (
            <div class="actions">
              {ctas.map((cta) => (
                <a
                  class={`btn ${cta.variant === "primary" ? "primary" : ""}`}
                  href={cta.href}
                  rel={cta.rel}
                >
                  {cta.label}
                </a>
              ))}
            </div>
          )
        }
      </div>
      <div class="hero-art">
        <TrustChainIsland client:visible />
      </div>
    </div>

    <div class="kpi" aria-label="Key performance indicators">
      <div class="card">
        <div class="eyebrow">Decision latency</div><h4>&lt; 10 ms p95</h4><div
          class="discrete"
        >
          Policy + graph
        </div>
      </div>
      <div class="card">
        <div class="eyebrow">Token issuance</div><h4>&lt; 120 ms p95</h4><div
          class="discrete"
        >
          DPoP / mTLS bound
        </div>
      </div>
      <div class="card">
        <div class="eyebrow">VC verification</div><h4>&lt; 150 ms p95</h4><div
          class="discrete"
        >
          SD-JWT & BBS+
        </div>
      </div>
      <div class="card">
        <div class="eyebrow">Availability</div><h4>99.95%</h4><div
          class="discrete"
        >
          Multi-region
        </div>
      </div>
    </div>
  </section>

  <section id="platform" class="section">
    <div class="container">
      <div class="grid cols-3">
        {
          PILLARS.map((pillar) => (
            <div class="card" id={`pillar-${pillar.id}`}>
              <div class="eyebrow">{pillar.eyebrow}</div>
              <h3>{pillar.title}</h3>
              <p>{pillar.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section id="how" class="section">
    <div class="container twocol">
      <div>
        <h2>How it works</h2>
        <div class="card" aria-label="Flow">
          <pre
            class="code"><code>1. Authenticate with passkey (FIDO2/WebAuthn)
2. Present minimal claims (OID4VP + SD‑JWT/BBS+)
3. Graph check + policy overlay → DPoP/mTLS‑bound token</code></pre>
        </div>
      </div>
      <div class="grid">
        <div class="card">
          <div class="eyebrow">Attestation</div><strong
            >Android Play Integrity · Apple App Attest · WebAuthn</strong
          ><br />Evidence-bound clients with rotation and per-device DPoP
          binding.
        </div>
        <div class="card">
          <div class="eyebrow">Proofing</div><strong
            >NIST 800‑63 / eIDAS mapping</strong
          ><br />Pluggable doc/biometric KYC → Proofing VC for onboarding &
          step‑up.
        </div>
      </div>
    </div>
  </section>

  <MissionSection />

  <section id="developers" class="section">
    <div class="container twocol">
      <div>
        <h2>For developers</h2>
        <p>
          SDKs for Java · Rust · JS/TS · Go · Swift, GraphQL + REST APIs, and a
          conformance harness. Spin up a sandbox tenant in minutes and test
          OIDC, GNAP, and VC flows with real tokens.
        </p>
        <div class="actions">
          <a class="btn" href="/docs">Browse APIs</a>
          <a class="btn" href="/play">Open Playground</a>
          <a class="btn" href="https://github.com/artagon" rel="noopener"
            >GitHub</a
          >
        </div>
      </div>
      <div class="card" aria-label="Quickstart">
        <div class="eyebrow">Quickstart (OIDC + DPoP)</div>
        <pre
          class="code"><code>curl -X POST $TOKEN_ENDPOINT \
 -H "DPoP: &lt;jwt&gt;" -H "Content-Type: application/x-www-form-urlencoded" \
 -d "grant_type=authorization_code&amp;code=..."</code></pre>
        <div class="discrete">
          Use our SDKs to generate DPoP and handle key rotation automatically.
        </div>
      </div>
    </div>
  </section>

  <section id="faq" class="section">
    <div class="container">
      <h2>Frequently asked questions</h2>
      <details>
        <summary>What is the Artagon Identity Platform?</summary><p>
          Artagon combines an OIDC 2.1/OpenID Provider, a GNAP Authorization
          Server, verifiable credentials, device/app attestation, and
          Zanzibar‑style policy in one platform.
        </p>
      </details>
      <details>
        <summary>Does Artagon support OIDC 2.1 and GNAP?</summary><p>
          Yes—OIDC 2.1 with hardened OAuth (PAR · JAR/JARM · RAR · DPoP · mTLS)
          and GNAP with proof‑of‑possession and continuation handles.
        </p>
      </details>
      <details>
        <summary>Do you support passkeys and verifiable credentials?</summary><p
        >
          Yes—passkey/WebAuthn is primary auth, and we issue/verify SD‑JWT &
          BBS+ VCs via OID4VCI/OID4VP.
        </p>
      </details>
      <details>
        <summary>How does authorization work?</summary><p>
          A Zanzibar graph powers fast relationship checks while policies in
          XACML, Cedar, or OPA apply fine‑grained controls and obligations.
        </p>
      </details>
    </div>
  </section>

  {
    latestPosts.length > 0 && (
      <section class="writing-strip section" id="writing">
        <div class="container">
          <header class="writing-strip__head">
            <h2>Field notes from the team building Artagon.</h2>
            <a class="writing-strip__more" href="/writing">All writing →</a>
          </header>
          <ul role="list" class="writing-strip__list">
            {latestPosts.map((post) => (
              <li class="writing-strip__item">
                <a class="writing-strip__link" href={`/writing/${post.id}`}>
                  <time
                    class="writing-strip__date"
                    datetime={post.data.published.toISOString()}
                  >
                    {dateFmt.format(post.data.published)}
                  </time>
                  <h3 class="writing-strip__title">{post.data.headline}</h3>
                  <p class="writing-strip__lede">{post.data.lede}</p>
                  <span class="writing-strip__cta">Read →</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </section>
    )
  }

  {
    onRamp && (
      <section class="onramp section" id="get-started">
        <div class="container">
          <div class="onramp__card">
            <div class="onramp__strip">
              <span>{onRamp.programLabel}</span>
              <span>{onRamp.statusLabel}</span>
            </div>
            <div class="onramp__grid">
              <div class="onramp__lead">
                <h2 class="onramp__headline">{onRamp.headline}</h2>
                <p class="onramp__lede">{onRamp.lede}</p>
                {onRamp.ctas.length > 0 && (
                  <div class="actions">
                    {onRamp.ctas.map((c) => (
                      <a
                        class={`btn ${c.variant === "primary" ? "primary" : ""}`}
                        href={c.href}
                        rel={c.rel}
                      >
                        {c.label}
                      </a>
                    ))}
                  </div>
                )}
              </div>
              <aside class="onramp__contacts" aria-label={onRamp.contactsTitle}>
                <div class="onramp__contacts-title">{onRamp.contactsTitle}</div>
                <dl class="onramp__rows">
                  {ORG.contacts.map((r) => (
                    <div class="onramp__row">
                      <dt>{r.label}</dt>
                      <dd>{r.value}</dd>
                    </div>
                  ))}
                </dl>
                {ORG.contactFootnote && (
                  <p class="onramp__footnote">{ORG.contactFootnote}</p>
                )}
              </aside>
            </div>
          </div>
        </div>
      </section>
    )
  }

  <Fragment slot="footer"><Footer /></Fragment>
</Base>

<style>
  /* USMR Phase 5.1j — hero typography matches new-design global.css
   * (h1 clamp 56-108px, line-height 0.94, letter-spacing -0.035em).
   * Overrides the legacy .hero h1 rule in public/assets/theme.css. */
  .hero__eyebrow-tag {
    margin-bottom: 28px;
  }
  .hero h1.display {
    font-size: clamp(3.5rem, 7.2vw, 6.75rem);
    line-height: 0.94;
    letter-spacing: -0.035em;
    font-weight: 400;
    margin: 0 0 32px;
    font-family: var(--f-display, "Space Grotesk", "Inter Tight", sans-serif);
  }
  .hero h1.display br + * {
    display: inline;
  }

  .onramp {
    padding-block: var(--space-12);
  }
  .onramp__card {
    position: relative;
    border: 1px solid var(--line);
    border-radius: 16px;
    padding: clamp(2rem, 4vw, 4.5rem) clamp(1.25rem, 3vw, 4rem);
    background: linear-gradient(135deg, var(--bg-1) 0%, var(--bg) 80%);
    overflow: hidden;
  }
  .onramp__strip {
    position: absolute;
    top: 1rem;
    left: 1.25rem;
    right: 1.25rem;
    display: flex;
    justify-content: space-between;
    font-family: ui-monospace, Menlo, Consolas, monospace;
    font-size: var(--fs-micro);
    color: var(--fg-2);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .onramp__grid {
    display: grid;
    gap: clamp(1.5rem, 3vw, 3rem);
    grid-template-columns: minmax(0, 1.6fr) minmax(0, 1fr);
    margin-top: 2rem;
  }
  @media (max-width: 768px) {
    .onramp__grid {
      grid-template-columns: 1fr;
    }
  }
  .onramp__headline {
    font-size: var(--fs-h2);
    line-height: 1.05;
    margin: 0 0 1.5rem;
  }
  .onramp__lede {
    margin: 0 0 2rem;
    max-width: 52ch;
    color: var(--fg-2);
  }
  .onramp__contacts {
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 1.75rem;
    background: var(--bg-1);
    font-family: ui-monospace, Menlo, Consolas, monospace;
    font-size: var(--fs-small);
  }
  .onramp__contacts-title {
    font-size: var(--fs-micro);
    color: var(--fg-2);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: 0.875rem;
  }
  .onramp__rows {
    margin: 0;
    display: grid;
    gap: 0.5rem;
  }
  .onramp__row {
    display: grid;
    grid-template-columns: minmax(0, 0.6fr) minmax(0, 1fr);
    gap: 1rem;
  }
  .onramp__row dt {
    color: var(--fg-2);
    margin: 0;
  }
  .onramp__row dd {
    color: var(--fg);
    margin: 0;
  }
  .onramp__footnote {
    margin: 0.875rem 0 0;
    color: var(--fg-2);
    font-size: var(--fs-micro);
    line-height: 1.5;
  }

  /* USMR Phase 5.1f — latest writing strip */
  .writing-strip {
    padding-block: var(--space-12);
  }
  .writing-strip__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-6);
    margin-block-end: var(--space-8);
    flex-wrap: wrap;
  }
  .writing-strip__head h2 {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    line-height: 1.15;
    margin: 0;
    max-width: 28ch;
  }
  .writing-strip__more {
    font-family: ui-monospace, Menlo, Consolas, monospace;
    font-size: 0.875rem;
    color: var(--accent);
    text-decoration: none;
    white-space: nowrap;
  }
  .writing-strip__more:hover,
  .writing-strip__more:focus-visible {
    text-decoration: underline;
  }
  .writing-strip__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--space-6);
    grid-template-columns: repeat(3, 1fr);
  }
  @media (max-width: 900px) {
    .writing-strip__list {
      grid-template-columns: 1fr;
    }
  }
  .writing-strip__link {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    height: 100%;
    padding: var(--space-6);
    border: 1px solid var(--line);
    border-radius: 12px;
    color: inherit;
    text-decoration: none;
    background: var(--bg-1);
    transition:
      border-color 0.15s ease,
      transform 0.15s ease;
  }
  .writing-strip__link:hover,
  .writing-strip__link:focus-visible {
    border-color: var(--accent);
    transform: translateY(-2px);
  }
  .writing-strip__date {
    font-family: ui-monospace, Menlo, Consolas, monospace;
    font-size: var(--fs-micro);
    color: var(--fg-2);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .writing-strip__title {
    font-size: 1.25rem;
    line-height: 1.25;
    margin: 0;
  }
  .writing-strip__lede {
    color: var(--fg-2);
    line-height: 1.55;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .writing-strip__cta {
    margin-top: auto;
    font-family: ui-monospace, Menlo, Consolas, monospace;
    font-size: var(--fs-micro);
    color: var(--accent);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
</style>
