---
// USMR Phase 5.5.11 Task #30 — `/writing/[slug]` detail route ported
// to the canonical `.blog-hero` + `.post-body` shape from
// new-design/extracted/src/pages/post-*.html. Five sub-deltas closed
// in this revision:
//   1. Hero shell uses canonical `.blog-hero` + `.blog-wrap` (760px
//      max-width, 1px line-soft bottom hairline) instead of generic
//      `.post__hero`.
//   2. Eyebrow renders `← Blog · {Tag}` with backlink instead of static
//      `<p>{eyebrow}</p>`.
//   3. `.blog-hero .sub` styled as Fraunces italic clamp(18-22px) per
//      canonical post-trusted-identity.html:345.
//   4. Byline emits `Author · Date · {N} min read` with monospace 3px
//      round dots. Author resolves through the `authors` collection;
//      reading-time computed via shared `src/lib/reading-time.ts`.
//   5. Post-body primitives (.lede, .pull, .chain-fig, .chain-row,
//      .compare, inline `<code>` chip, `h2 .num`) styled as :global
//      classes the MDX posts can opt into.
//   + Footer ribbon: `.post-footer` with tags + 3-card CTA row
//      (Apply / Read docs / GitHub).
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { readingMinutes } from '../../lib/reading-time.ts';

export async function getStaticPaths() {
  const posts = await getCollection('writing');
  return posts
    .filter((p) => !p.data.draft)
    .map((post) => ({
      params: { slug: post.id },
      props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Author resolution — mirrors /writing/index.astro:35-36, 99.
const authors = await getCollection('authors');
const authorByName = new Map(authors.map((a) => [a.id, a.data.name]));
const authorName = post.data.author ? authorByName.get(post.data.author) : undefined;

// Date format — short month form for the byline (canonical post-*.html shows "21 Apr 2026").
const byleDateFmt = new Intl.DateTimeFormat('en-GB', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

const minutes = readingMinutes(post.body);

// Eyebrow renders `← Blog · {Tag}`. Use first tag as the canonical
// label; the frontmatter `eyebrow` is a non-empty schema-required
// fallback for tag-less posts. (USMR 5.5.14 — dropped the
// `?? 'Field notes'` literal-string tail; it was unreachable since
// content.config.ts requires `eyebrow: z.string().min(1)`.)
const primaryTag = post.data.tags[0] ?? post.data.eyebrow;

// Post-specific og:image / og:type / publish dates / tags through to
// SeoTags (USMR 5.1q.7 — Article JSON-LD).
const articleImage = post.data.cover ?? '/assets/logos/og-image.png';
---

<Base
  title={`${post.data.title} — Artagon`}
  description={post.data.description}
  path={`/writing/${post.id}`}
  image={articleImage}
  type="article"
  publishedTime={post.data.published.toISOString()}
  modifiedTime={post.data.updated?.toISOString()}
  tags={post.data.tags}
>
  <Fragment slot="header"><Header /></Fragment>

  <main id="main">
    <article class="post">
      <section class="blog-hero" aria-labelledby="post-h1">
        <div class="blog-wrap">
          <p class="blog-hero__eyebrow">
            <a class="blog-hero__back" href="/writing">← Blog</a>
            <span class="blog-hero__sep" aria-hidden="true">·</span>
            <span>{primaryTag}</span>
          </p>
          <h1 id="post-h1" class="blog-hero__title display">{post.data.headline}</h1>
          <p class="blog-hero__sub">{post.data.lede}</p>
          <div class="blog-hero__byline">
            {authorName && (
              <Fragment>
                <span>{authorName}</span>
                <span class="blog-hero__dot" aria-hidden="true" />
              </Fragment>
            )}
            <time datetime={post.data.published.toISOString()}>
              {byleDateFmt.format(post.data.published)}
            </time>
            <span class="blog-hero__dot" aria-hidden="true" />
            <span>{minutes} min read</span>
            {post.data.updated && post.data.updated > post.data.published && (
              <Fragment>
                <span class="blog-hero__dot" aria-hidden="true" />
                <span>updated {byleDateFmt.format(post.data.updated)}</span>
              </Fragment>
            )}
          </div>
        </div>
      </section>

      <section class="post-body-section">
        <div class="blog-wrap post-body">
          <Content />
        </div>
      </section>

      <section class="post-footer-section">
        <div class="blog-wrap post-footer">
          {post.data.tags && post.data.tags.length > 0 && (
            <div class="post-footer__tags">
              {post.data.tags.map((tag) => <span>{tag}</span>)}
            </div>
          )}
          <div class="post-footer__cta-row">
            <a class="post-footer__cta-card" href="#get-started">
              <div class="post-footer__cta-eyebrow">Design partners</div>
              <h3>Request access</h3>
              <p>Try Artagon in your own stack. Small cohort, hands-on.</p>
              <div class="post-footer__cta-arrow">→ Apply</div>
            </a>
            <a class="post-footer__cta-card" href="/platform">
              <div class="post-footer__cta-eyebrow">Developers</div>
              <h3>Platform docs</h3>
              <p>Architecture, primitives, and the playground.</p>
              <div class="post-footer__cta-arrow">→ Explore</div>
            </a>
            <a
              class="post-footer__cta-card"
              href="https://github.com/artagon"
              target="_blank"
              rel="noopener noreferrer"
            >
              <div class="post-footer__cta-eyebrow">Community</div>
              <h3>Follow on GitHub</h3>
              <p>Reference implementations and standards work.</p>
              <div class="post-footer__cta-arrow">→ github.com/artagon</div>
            </a>
          </div>
        </div>
      </section>
    </article>
  </main>

  <Fragment slot="footer"><Footer /></Fragment>
</Base>

<style>
  /* USMR Phase 5.5.11 Task #30 — canonical post detail styles ported
   * from new-design/extracted/src/pages/post-*.html. Hero shell, body
   * primitives (.lede, .pull, .chain-fig, .compare, inline code chip,
   * h2 .num), and post-footer ribbon. */

  .post {
    background: var(--bg);
  }
  .blog-wrap {
    max-width: 760px;
    margin-inline: auto;
    padding-inline: clamp(24px, 4vw, 40px);
  }

  /* ----- Hero ----- */
  .blog-hero {
    padding-block: 80px 56px;
    border-bottom: 1px solid var(--line-soft);
  }
  /* Canonical .eyebrow per post-trusted-identity.html:243-249 — font
   * 12 / fg-2 / tracking 0.1em / margin-bottom 24. We had 11 / fg-3 /
   * 0.12em / 20 — slightly tighter and dimmer than canonical. The
   * generic .eyebrow ::before accent dash is omitted on purpose for
   * the blog-hero variant (the "← Blog" backlink IS the visual
   * element; an extra dash before the arrow reads as clutter). */
  .blog-hero__eyebrow {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--f-mono);
    font-size: 12px;
    color: var(--fg-2);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin: 0 0 24px;
  }
  .blog-hero__back {
    color: var(--fg-3);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .blog-hero__back:hover,
  .blog-hero__back:focus-visible {
    color: var(--accent);
  }
  .blog-hero__sep {
    color: var(--fg-3);
  }
  /* Canonical post-trusted-identity.html:338-344 — `clamp(40, 68)` /
   * line-height 1.02 / margin-bottom 24. We had 72 / 1.05 / 18 — the
   * larger ceiling broke 22ch wrap on widest viewports and the looser
   * line-height + tighter margin made the headline feel cramped
   * against the lede. */
  /* Canonical post-trusted-identity.html h1 — `font-weight: 400`
   * (regular Space Grotesk, h1-specific override of catch-all 500
   * per pt31). Pre-fix used `var(--display-weight, 500)` which
   * forced 500 on every post-detail h1 since [data-hero-font]
   * doesn't override --display-weight to 400 except for fraunces /
   * dmserif / mono variants. */
  .blog-hero__title {
    font-family: var(--f-display);
    font-size: clamp(40px, 5.4vw, 68px);
    line-height: 1.02;
    letter-spacing: var(--display-tracking, -0.025em);
    color: var(--fg);
    margin: 0 0 24px;
    max-width: 22ch;
  }
  .blog-hero__sub {
    color: var(--fg-2);
    font-size: clamp(18px, 1.6vw, 22px);
    line-height: 1.45;
    max-width: 60ch;
    margin: 0 0 36px;
    font-family: var(--f-emphasis, var(--f-serif));
    font-style: italic;
  }
  /* Canonical post-trusted-identity.html:346-350 — gap 14, color fg-2.
   * We had gap 10 / fg-3 — tighter spacing + dimmer color buried the
   * byline against the dot separators. fg-2 is the editorial-meta
   * color used across the site. */
  .blog-hero__byline {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 14px;
    font-family: var(--f-mono);
    font-size: 12px;
    color: var(--fg-2);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .blog-hero__dot {
    width: 3px;
    height: 3px;
    border-radius: 99px;
    background: var(--fg-3);
    flex-shrink: 0;
  }

  /* ----- Body section ----- */
  .post-body-section {
    padding-block: 48px 72px;
  }
  .post-body {
    font-size: 17px;
    line-height: 1.7;
    color: var(--fg-1);
  }
  .post-body :global(p) {
    margin: 0 0 22px;
    max-width: 64ch;
  }
  .post-body :global(.lede) {
    font-size: 20px;
    line-height: 1.55;
    color: var(--fg);
    max-width: 60ch;
  }
  /* Canonical post-body h2 — new-design blog.html:356-366. Top margin
   * 64 (was 56), max font 34 (was 32), line-height 1.12 (was 1.15);
   * the `.num` mono prefix renders as a *block* above the heading
   * with `margin-bottom: 8px`, NOT inline-`vertical-align: middle`. */
  .post-body :global(h2) {
    margin: 64px 0 18px;
    font-family: var(--f-display);
    font-size: clamp(26px, 2.4vw, 34px);
    line-height: 1.12;
    letter-spacing: -0.02em;
    color: var(--fg);
    font-weight: 500;
  }
  .post-body :global(h2 .num) {
    display: block;
    margin-bottom: 8px;
    font-family: var(--f-mono);
    font-size: 11px;
    color: var(--fg-3);
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .post-body :global(h3) {
    margin: 40px 0 14px;
    font-size: 20px;
    font-weight: 500;
    color: var(--fg);
  }
  .post-body :global(ul),
  .post-body :global(ol) {
    margin: 0 0 26px;
    padding-left: 22px;
    max-width: 64ch;
  }
  .post-body :global(li) {
    margin-bottom: 8px;
    color: var(--fg-1);
  }
  .post-body :global(strong) {
    color: var(--fg);
    font-weight: 500;
  }
  .post-body :global(em) {
    font-family: var(--f-emphasis, var(--f-serif));
    font-style: italic;
    color: var(--fg);
  }
  /* Canonical inline code — blog.html:372-376. Neutral bg-1 + line-soft
   * border, NOT the accent-tinted variant. The accent tint masked
   * inline-code as the same affordance as a button or link, breaking
   * scan-ability inside long-form prose. */
  .post-body :global(code) {
    font-family: var(--f-mono);
    font-size: 0.88em;
    color: var(--fg);
    background: var(--bg-1);
    border: 1px solid var(--line-soft);
    border-radius: 4px;
    padding: 1px 6px;
  }
  /* Canonical .pull — blog.html:378-388. Full 1px solid var(--line)
   * border + 36 px padding + 32 px max font / 1.3 line-height. The
   * accent left-stripe variant we shipped read as a sidebar callout,
   * not the editorial pull-quote the canonical narrates. */
  .post-body :global(blockquote),
  .post-body :global(.pull) {
    font-family: var(--f-emphasis, var(--f-serif));
    font-style: italic;
    font-size: clamp(24px, 2.4vw, 32px);
    line-height: 1.3;
    color: var(--fg);
    margin: 36px 0;
    padding: 36px;
    background: linear-gradient(180deg, color-mix(in oklab, var(--accent) 4%, var(--bg-1)) 0%, var(--bg-1) 100%);
    border: 1px solid var(--line);
    border-radius: 8px;
  }
  /* Canonical post-trusted-identity.html:388-391 — `.pull .attribution
   * { margin-top: 18; letter-spacing: 0.14em }`. Pre-fix margin-top
   * 14 + tracking 0.08em — both undersized. The 0.14em tracking is
   * the canonical "uppercase legal/byline" spacing used across mono
   * eyebrows. */
  .post-body :global(.pull .attribution) {
    display: block;
    margin-top: 18px;
    font-family: var(--f-mono);
    font-style: normal;
    font-size: 11px;
    color: var(--fg-3);
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  /* Canonical post-trusted-identity.html:394-398 — `margin: 32px 0
   * 40px` (asymmetric — narrower above, wider below for the caption),
   * `border: 1px solid var(--line)` (not the softer line-soft),
   * `border-radius: 14`, `background: linear-gradient(180deg, bg-1 →
   * bg)`. We had symmetric 36 / line-soft / 12 / flat bg-1 — the
   * gradient + thicker border give the figure the canonical
   * card-on-canvas weight that contains the boxed chain-row stack. */
  .post-body :global(.chain-fig) {
    margin: 32px 0 40px;
    padding: 24px;
    border: 1px solid var(--line);
    border-radius: 14px;
    background: linear-gradient(180deg, var(--bg-1) 0%, var(--bg) 100%);
    display: grid;
    gap: 8px;
    max-width: none;
  }
  /* Canonical .chain-row — blog.html:401. 40 px first column (room for
   * the mono index), 14 16 padding, per-row 1px solid var(--line-soft)
   * frame + var(--bg) backdrop. The pre-canonical 28 px first col +
   * border-top divider rendered as a list, not the boxed-row stage
   * card the canonical narrates. */
  /* Canonical post-trusted-identity.html:400-407 — `border-radius:
   * 10`, `font-size: 14`. Inter-row spacing comes from the `.chain-fig
   * { display: grid; gap: 8px }` parent, NOT a per-row margin. Our
   * 5.5.16-pt1 port used border-radius 8 + per-row margin-bottom 8;
   * canonicalizing to 10 + grid-gap brings the boxed chain-rows
   * exactly in line. */
  .post-body :global(.chain-row) {
    display: grid;
    grid-template-columns: 40px 1fr auto;
    gap: 14px;
    padding: 14px 16px;
    align-items: center;
    border: 1px solid var(--line-soft);
    border-radius: 10px;
    background: var(--bg);
    font-size: 14px;
    position: relative;
  }
  /* Canonical post-trusted-identity.html:408-411 — accent connector
   * line in the 8 px gap between adjacent chain-rows. Anchors at the
   * .num circle x-position (34 px from row left = 24 padding + 10 to
   * center). The line teaches the reader that each row inherits state
   * from the previous one. */
  .post-body :global(.chain-row + .chain-row::before) {
    content: "";
    position: absolute;
    left: 34px;
    top: -8px;
    width: 1px;
    height: 8px;
    background: var(--accent);
  }
  /* Canonical post-trusted-identity.html:412-419 — chain-row .num
   * is a 28×28 accent-bordered circle, NOT a flat label. The mono
   * 10 px text sits centered with `display: grid; place-items:
   * center`. Accent-tinted bg + accent box-shadow give it the
   * canonical "glowing node" look that visually anchors each stage
   * row. The pre-canonical flat-text .num made the .chain-row read
   * as a list, not a stage-card sequence. */
  .post-body :global(.chain-row .num) {
    width: 28px;
    height: 28px;
    border-radius: 99px;
    border: 1.5px solid var(--accent);
    display: grid;
    place-items: center;
    font-family: var(--f-mono);
    font-size: 10px;
    color: var(--accent);
    font-weight: 600;
    background: color-mix(in oklab, var(--accent) 14%, transparent);
    box-shadow: 0 0 16px color-mix(in oklab, var(--accent) 50%, transparent);
  }
  .post-body :global(.chain-row .label) {
    font-size: 15px;
    font-weight: 500;
    color: var(--fg);
  }
  .post-body :global(.chain-row .sub) {
    display: block;
    font-family: var(--f-mono);
    font-size: 11px;
    color: var(--fg-3);
    margin-top: 3px;
    letter-spacing: 0.02em;
  }
  .post-body :global(.chain-row .tag) {
    font-family: var(--f-mono);
    font-size: 10px;
    color: var(--accent);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .post-body :global(.chain-caption) {
    display: block;
    margin-top: 14px;
    font-family: var(--f-mono);
    font-size: 11px;
    color: var(--fg-3);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-align: center;
  }
  /* Canonical post-trusted-identity.html:428-429 — `gap: 16` (we had
   * 20). The tighter gap reads as a comparison pair instead of two
   * independent cards. */
  .post-body :global(.compare) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin: 36px 0;
  }
  .post-body :global(.compare .col) {
    /* Canonical post-trusted-identity.html:431-433 — `padding: 22`,
     * `border-radius: 12`. We had border-radius 8 — the larger
     * radius matches the .chain-fig card-on-canvas weight. */
    padding: 22px;
    border: 1px solid var(--line-soft);
    border-radius: 12px;
    background: var(--bg-1);
  }
  .post-body :global(.compare .col.before) {
    opacity: 0.75;
  }
  /* Canonical post-trusted-identity.html:438 — `margin-bottom: 14`
   * (we had 12). The 2 px shortfall compressed the gap between the
   * BEFORE/AFTER label and the column body text. */
  .post-body :global(.compare .col .h) {
    font-family: var(--f-mono);
    font-size: 11px;
    color: var(--fg-3);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 14px;
  }
  .post-body :global(.compare .col.after .h) {
    color: var(--accent);
  }
  .post-body :global(.compare .col p) {
    margin: 0;
    font-size: 14px;
    line-height: 1.55;
    color: var(--fg-1);
    max-width: none;
  }
  .post-body :global(.compare .col p + p) {
    margin-top: 10px;
  }
  @media (max-width: 720px) {
    .post-body :global(.compare) {
      grid-template-columns: 1fr;
    }
  }

  /* Canonical post-trusted-identity.html:444-446 — `padding: 48px 0
   * 48px`, symmetric. We had 32 top / 80 bottom which read as too-
   * tight under the post body and over-padded above the footer. */
  .post-footer-section {
    padding-block: 48px;
    border-top: 1px solid var(--line-soft);
  }
  .post-footer__tags {
    font-family: var(--f-mono);
    font-size: 11px;
    color: var(--fg-3);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 32px;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .post-footer__tags span {
    padding: 5px 11px;
    border: 1px solid var(--line-soft);
    border-radius: 99px;
    color: var(--fg-2);
  }
  .post-footer__cta-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  @media (max-width: 720px) {
    .post-footer__cta-row {
      grid-template-columns: 1fr;
    }
  }
  /* Canonical post-footer CTA cards — blog.html:452-453. 26 px
   * padding all sides + var(--line) border (not line-soft) + no fixed
   * min-height. The card height adapts to its title + description; the
   * pre-canonical 20×22 + 156 min-height locked rows even when the
   * description was a single line, leaving wide whitespace. */
  .post-footer__cta-card {
    /* Canonical post-trusted-identity.html:452-453 — `border-radius:
     * 14px` (we shipped 12 in 5.5.16-pt1). Subtle but the canonical
     * radius matches the .onramp__card 16px / .post-body chain-fig
     * 12px family — 14 lands the post-footer cards midway, which
     * reads as the canonical visual rhythm. */
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 26px;
    border: 1px solid var(--line);
    border-radius: 14px;
    background: var(--bg-1);
    text-decoration: none;
    color: inherit;
    transition:
      border-color 0.18s ease,
      background 0.18s ease,
      transform 0.18s ease;
  }
  .post-footer__cta-card:hover,
  .post-footer__cta-card:focus-visible {
    border-color: var(--accent-dim, var(--accent));
    background: color-mix(in oklab, var(--accent) 6%, var(--bg-1));
  }
  .post-footer__cta-card:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .post-footer__cta-eyebrow {
    font-family: var(--f-mono);
    font-size: 10px;
    color: var(--accent);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .post-footer__cta-card h3 {
    font-family: var(--f-display);
    font-size: 19px;
    margin: 0;
    color: var(--fg);
    font-weight: 500;
    letter-spacing: -0.01em;
  }
  .post-footer__cta-card p {
    color: var(--fg-2);
    font-size: 13px;
    margin: 0;
    line-height: 1.5;
    max-width: none;
  }
  .post-footer__cta-arrow {
    margin-top: auto;
    padding-top: 10px;
    font-family: var(--f-mono);
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 0.06em;
  }

  @media (forced-colors: active) {
    .post-footer__cta-card:hover,
    .post-footer__cta-card:focus-visible {
      background: Canvas;
      border-color: Highlight;
    }
    .post-body :global(.pull),
    .post-body :global(blockquote) {
      background: Canvas;
      border-color: Highlight;
    }
  }
</style>
