---
// USMR Phase 5.5.11 Task #30 — `/writing/[slug]` detail route ported
// to the canonical `.blog-hero` + `.post-body` shape from
// new-design/extracted/src/pages/post-*.html. Five sub-deltas closed
// in this revision:
//   1. Hero shell uses canonical `.blog-hero` + `.blog-wrap` (760px
//      max-width, 1px line-soft bottom hairline) instead of generic
//      `.post__hero`.
//   2. Eyebrow renders `← Blog · {Tag}` with backlink instead of static
//      `<p>{eyebrow}</p>`.
//   3. `.blog-hero .sub` styled as Fraunces italic clamp(18-22px) per
//      canonical post-trusted-identity.html:345.
//   4. Byline emits `Author · Date · {N} min read` with monospace 3px
//      round dots. Author resolves through the `authors` collection;
//      reading-time computed via shared `src/lib/reading-time.ts`.
//   5. Post-body primitives (.lede, .pull, .chain-fig, .chain-row,
//      .compare, inline `<code>` chip, `h2 .num`) styled as :global
//      classes the MDX posts can opt into.
//   + Footer ribbon: `.post-footer` with tags + 3-card CTA row
//      (Apply / Read docs / GitHub).
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { readingMinutes } from '../../lib/reading-time.ts';

export async function getStaticPaths() {
  const posts = await getCollection('writing');
  return posts
    .filter((p) => !p.data.draft)
    .map((post) => ({
      params: { slug: post.id },
      props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Author resolution — mirrors /writing/index.astro:35-36, 99.
const authors = await getCollection('authors');
const authorByName = new Map(authors.map((a) => [a.id, a.data.name]));
const authorName = post.data.author ? authorByName.get(post.data.author) : undefined;

// Date format — short month form for the byline (canonical post-*.html shows "21 Apr 2026").
const byleDateFmt = new Intl.DateTimeFormat('en-GB', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

const minutes = readingMinutes(post.body);

// Eyebrow renders `← Blog · {Tag}`. Use first tag as the canonical
// label; falls back to the frontmatter `eyebrow` field if no tags.
const primaryTag = (post.data.tags && post.data.tags[0]) ?? post.data.eyebrow ?? 'Field notes';

// Post-specific og:image / og:type / publish dates / tags through to
// SeoTags (USMR 5.1q.7 — Article JSON-LD).
const articleImage = post.data.cover ?? '/assets/logos/og-image.png';
---

<Base
  title={`${post.data.title} — Artagon`}
  description={post.data.description}
  path={`/writing/${post.id}`}
  image={articleImage}
  type="article"
  publishedTime={post.data.published.toISOString()}
  modifiedTime={post.data.updated?.toISOString()}
  tags={post.data.tags}
>
  <Fragment slot="header"><Header /></Fragment>

  <main id="main">
    <article class="post">
      <section class="blog-hero" aria-labelledby="post-h1">
        <div class="blog-wrap">
          <p class="blog-hero__eyebrow">
            <a class="blog-hero__back" href="/writing">← Blog</a>
            <span class="blog-hero__sep" aria-hidden="true">·</span>
            <span>{primaryTag}</span>
          </p>
          <h1 id="post-h1" class="blog-hero__title display">{post.data.headline}</h1>
          <p class="blog-hero__sub">{post.data.lede}</p>
          <div class="blog-hero__byline">
            {authorName && (
              <Fragment>
                <span>{authorName}</span>
                <span class="blog-hero__dot" aria-hidden="true" />
              </Fragment>
            )}
            <time datetime={post.data.published.toISOString()}>
              {byleDateFmt.format(post.data.published)}
            </time>
            <span class="blog-hero__dot" aria-hidden="true" />
            <span>{minutes} min read</span>
            {post.data.updated && post.data.updated > post.data.published && (
              <Fragment>
                <span class="blog-hero__dot" aria-hidden="true" />
                <span>updated {byleDateFmt.format(post.data.updated)}</span>
              </Fragment>
            )}
          </div>
        </div>
      </section>

      <section class="post-body-section">
        <div class="blog-wrap post-body">
          <Content />
        </div>
      </section>

      <section class="post-footer-section">
        <div class="blog-wrap post-footer">
          {post.data.tags && post.data.tags.length > 0 && (
            <div class="post-footer__tags">
              {post.data.tags.map((tag) => <span>{tag}</span>)}
            </div>
          )}
          <div class="post-footer__cta-row">
            <a class="post-footer__cta-card" href="#get-started">
              <div class="post-footer__cta-eyebrow">Design partners</div>
              <h3>Request access</h3>
              <p>Try Artagon in your own stack. Small cohort, hands-on.</p>
              <div class="post-footer__cta-arrow">→ Apply</div>
            </a>
            <a class="post-footer__cta-card" href="/platform">
              <div class="post-footer__cta-eyebrow">Developers</div>
              <h3>Platform docs</h3>
              <p>Architecture, primitives, and the playground.</p>
              <div class="post-footer__cta-arrow">→ Explore</div>
            </a>
            <a
              class="post-footer__cta-card"
              href="https://github.com/artagon"
              target="_blank"
              rel="noopener noreferrer"
            >
              <div class="post-footer__cta-eyebrow">Community</div>
              <h3>Follow on GitHub</h3>
              <p>Reference implementations and standards work.</p>
              <div class="post-footer__cta-arrow">→ github.com/artagon</div>
            </a>
          </div>
        </div>
      </section>
    </article>
  </main>

  <Fragment slot="footer"><Footer /></Fragment>
</Base>

<style>
  /* USMR Phase 5.5.11 Task #30 — canonical post detail styles ported
   * from new-design/extracted/src/pages/post-*.html. Hero shell, body
   * primitives (.lede, .pull, .chain-fig, .compare, inline code chip,
   * h2 .num), and post-footer ribbon. */

  .post {
    background: var(--bg);
  }
  .blog-wrap {
    max-width: 760px;
    margin-inline: auto;
    padding-inline: clamp(24px, 4vw, 40px);
  }

  /* ----- Hero ----- */
  .blog-hero {
    padding-block: 80px 56px;
    border-bottom: 1px solid var(--line-soft);
  }
  .blog-hero__eyebrow {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--f-mono);
    font-size: 11px;
    color: var(--fg-3);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin: 0 0 20px;
  }
  .blog-hero__back {
    color: var(--fg-3);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .blog-hero__back:hover,
  .blog-hero__back:focus-visible {
    color: var(--accent);
  }
  .blog-hero__sep {
    color: var(--fg-3);
  }
  .blog-hero__title {
    font-family: var(--f-display);
    font-size: clamp(40px, 5.4vw, 72px);
    line-height: 1.05;
    letter-spacing: var(--display-tracking, -0.025em);
    font-weight: var(--display-weight, 500);
    color: var(--fg);
    margin: 0 0 18px;
    max-width: 22ch;
  }
  .blog-hero__sub {
    color: var(--fg-2);
    font-size: clamp(18px, 1.6vw, 22px);
    line-height: 1.45;
    max-width: 60ch;
    margin: 0 0 36px;
    font-family: var(--f-emphasis, var(--f-serif));
    font-style: italic;
  }
  .blog-hero__byline {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 10px;
    font-family: var(--f-mono);
    font-size: 12px;
    color: var(--fg-3);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .blog-hero__dot {
    width: 3px;
    height: 3px;
    border-radius: 99px;
    background: var(--fg-3);
    flex-shrink: 0;
  }

  /* ----- Body section ----- */
  .post-body-section {
    padding-block: 48px 72px;
  }
  .post-body {
    font-size: 17px;
    line-height: 1.7;
    color: var(--fg-1);
  }
  .post-body :global(p) {
    margin: 0 0 22px;
    max-width: 64ch;
  }
  .post-body :global(.lede) {
    font-size: 20px;
    line-height: 1.55;
    color: var(--fg);
    max-width: 60ch;
  }
  .post-body :global(h2) {
    margin: 56px 0 18px;
    font-family: var(--f-display);
    font-size: clamp(24px, 2.4vw, 32px);
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--fg);
    font-weight: 500;
  }
  .post-body :global(h2 .num) {
    font-family: var(--f-mono);
    font-size: 11px;
    color: var(--fg-3);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-right: 10px;
    vertical-align: middle;
  }
  .post-body :global(h3) {
    margin: 40px 0 14px;
    font-size: 20px;
    font-weight: 500;
    color: var(--fg);
  }
  .post-body :global(ul),
  .post-body :global(ol) {
    margin: 0 0 26px;
    padding-left: 22px;
    max-width: 64ch;
  }
  .post-body :global(li) {
    margin-bottom: 8px;
    color: var(--fg-1);
  }
  .post-body :global(strong) {
    color: var(--fg);
    font-weight: 500;
  }
  .post-body :global(em) {
    font-family: var(--f-emphasis, var(--f-serif));
    font-style: italic;
    color: var(--fg);
  }
  .post-body :global(code) {
    font-family: var(--f-mono);
    font-size: 0.9em;
    color: var(--accent);
    background: color-mix(in oklab, var(--accent) 6%, transparent);
    border: 1px solid color-mix(in oklab, var(--accent) 18%, transparent);
    border-radius: 4px;
    padding: 1px 6px;
  }
  .post-body :global(blockquote),
  .post-body :global(.pull) {
    font-family: var(--f-emphasis, var(--f-serif));
    font-style: italic;
    font-size: clamp(20px, 2.2vw, 26px);
    line-height: 1.4;
    color: var(--fg);
    margin: 36px 0;
    padding: 28px 32px;
    background: linear-gradient(180deg, color-mix(in oklab, var(--accent) 4%, var(--bg-1)) 0%, var(--bg-1) 100%);
    border-left: 2px solid var(--accent);
    border-radius: 8px;
  }
  .post-body :global(.pull .attribution) {
    display: block;
    margin-top: 14px;
    font-family: var(--f-mono);
    font-style: normal;
    font-size: 11px;
    color: var(--fg-3);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .post-body :global(.chain-fig) {
    margin: 36px 0;
    padding: 24px;
    border: 1px solid var(--line-soft);
    border-radius: 12px;
    background: var(--bg-1);
    max-width: none;
  }
  .post-body :global(.chain-row) {
    display: grid;
    grid-template-columns: 28px 1fr auto;
    gap: 14px;
    padding: 14px 0;
    align-items: center;
    border-top: 1px solid var(--line-soft);
  }
  .post-body :global(.chain-row:first-child) {
    border-top: 0;
    padding-top: 0;
  }
  .post-body :global(.chain-row .num) {
    font-family: var(--f-mono);
    font-size: 11px;
    color: var(--fg-3);
    letter-spacing: 0.12em;
  }
  .post-body :global(.chain-row .label) {
    font-size: 15px;
    font-weight: 500;
    color: var(--fg);
  }
  .post-body :global(.chain-row .sub) {
    display: block;
    font-family: var(--f-mono);
    font-size: 11px;
    color: var(--fg-3);
    margin-top: 3px;
    letter-spacing: 0.02em;
  }
  .post-body :global(.chain-row .tag) {
    font-family: var(--f-mono);
    font-size: 10px;
    color: var(--accent);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .post-body :global(.chain-caption) {
    display: block;
    margin-top: 14px;
    font-family: var(--f-mono);
    font-size: 11px;
    color: var(--fg-3);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-align: center;
  }
  .post-body :global(.compare) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin: 36px 0;
  }
  .post-body :global(.compare .col) {
    padding: 24px;
    border: 1px solid var(--line-soft);
    border-radius: 8px;
    background: var(--bg-1);
  }
  .post-body :global(.compare .col.before) {
    opacity: 0.75;
  }
  .post-body :global(.compare .col .h) {
    font-family: var(--f-mono);
    font-size: 11px;
    color: var(--fg-3);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 12px;
  }
  .post-body :global(.compare .col.after .h) {
    color: var(--accent);
  }
  .post-body :global(.compare .col p) {
    margin: 0;
    font-size: 14px;
    line-height: 1.55;
    color: var(--fg-1);
    max-width: none;
  }
  .post-body :global(.compare .col p + p) {
    margin-top: 10px;
  }
  @media (max-width: 720px) {
    .post-body :global(.compare) {
      grid-template-columns: 1fr;
    }
  }

  /* ----- Footer ribbon ----- */
  .post-footer-section {
    padding-block: 32px 80px;
    border-top: 1px solid var(--line-soft);
  }
  .post-footer__tags {
    font-family: var(--f-mono);
    font-size: 11px;
    color: var(--fg-3);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 32px;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .post-footer__tags span {
    padding: 5px 11px;
    border: 1px solid var(--line-soft);
    border-radius: 99px;
    color: var(--fg-2);
  }
  .post-footer__cta-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  @media (max-width: 720px) {
    .post-footer__cta-row {
      grid-template-columns: 1fr;
    }
  }
  .post-footer__cta-card {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 20px 22px;
    min-height: 156px;
    border: 1px solid var(--line-soft);
    border-radius: 12px;
    background: var(--bg-1);
    text-decoration: none;
    color: inherit;
    transition:
      border-color 0.18s ease,
      background 0.18s ease,
      transform 0.18s ease;
  }
  .post-footer__cta-card:hover,
  .post-footer__cta-card:focus-visible {
    border-color: var(--accent-dim, var(--accent));
    background: color-mix(in oklab, var(--accent) 6%, var(--bg-1));
  }
  .post-footer__cta-card:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .post-footer__cta-eyebrow {
    font-family: var(--f-mono);
    font-size: 10px;
    color: var(--accent);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .post-footer__cta-card h3 {
    font-family: var(--f-display);
    font-size: 19px;
    margin: 0;
    color: var(--fg);
    font-weight: 500;
    letter-spacing: -0.01em;
  }
  .post-footer__cta-card p {
    color: var(--fg-2);
    font-size: 13px;
    margin: 0;
    line-height: 1.5;
    max-width: none;
  }
  .post-footer__cta-arrow {
    margin-top: auto;
    padding-top: 10px;
    font-family: var(--f-mono);
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 0.06em;
  }

  @media (forced-colors: active) {
    .post-footer__cta-card:hover,
    .post-footer__cta-card:focus-visible {
      background: Canvas;
      border-color: Highlight;
    }
    .post-body :global(.pull),
    .post-body :global(blockquote) {
      background: Canvas;
      border-color: Highlight;
    }
  }
</style>
