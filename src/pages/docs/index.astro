---
import Base from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Tagline from '../../components/Tagline.astro';
---
<Base
  title="Artagon Docs"
  description="Docs, APIs, SDKs, playground — coming with the design-partner program. Apply now to ship first."
  robots="noindex, nofollow"
>
  <Fragment slot="header"><Header /></Fragment>
  {/* USMR Phase 5.5.16-pt118 — pre-pt118 had TWO <h1> elements
      (a11y violation: only one h1 per page) AND both rendered at 102 px
      hero size (`var(--fs-h1)` default with no scoped sizing). pt117
      shipped the same fix for ShimPage; pt118 ports it to /docs which
      has its own structure. The "Documentation in preparation" h1 is
      promoted to h2 (single h1 per page rule). Both headings get the
      .display utility for canonical 500 weight + Space Grotesk. */}
  {/* USMR Phase 5.5.16-pt139 — landmark labelling. */}
  <section class="docs-hero" aria-labelledby="docs-hero-h">
    <div class="card docs-hero__card">
      <div>
        <div class="eyebrow">Docs</div>
        <h1 id="docs-hero-h" class="docs-hero__title display">Artagon Documentation</h1>
        <p class="docs-hero__lede lead">
          Developer-first. Real tokens. Real policies.
        </p>
      </div>
      <Tagline />
    </div>
  </section>
  {/* USMR Phase 5.5.14 — docs site is in preparation. Five earlier
     sidebar links (`/docs/quickstart`, `/docs/oidc`, `/docs/gnap`,
     `/docs/vc`, `/docs/policy`) all 404'd. Until those routes ship,
     the page is `noindex, nofollow` and surfaces a single CTA back
     to the design-partner program for early access. */}
  {/* USMR Phase 5.5.16-pt138 — was <main class="docs-main"> which
      nested inside BaseLayout's <main id="main-content">. Replaced
      with <div class="docs-main"> so the scoped CSS selectors
      (.docs-main, .docs-main__title, .docs-main__lede,
      .docs-main .actions) still resolve. */}
  <div class="docs-main">
    <article class="doc card">
      <h2 class="docs-main__title display">Documentation in preparation</h2>
      <p class="docs-main__lede lead">
        Full docs (Quickstart · OIDC 2.1 · GNAP · Verifiable Credentials · Policy &amp; Graph) ship with the design-partner program. Joining the cohort gets you early access plus paired implementation support.
      </p>
      <div class="actions">
        <a class="btn primary" href="/get-started">Apply as a design partner →</a>
        <a class="btn" href="/platform">Read the platform overview</a>
      </div>
    </article>
  </div>

  <style>
    .docs-hero,
    .docs-main {
      max-width: var(--maxw, 1240px);
      margin-inline: auto;
      padding-inline: clamp(24px, 4vw, 40px);
    }
    .docs-hero {
      padding-top: clamp(48px, 8vw, 80px);
    }
    .docs-main {
      padding-block: clamp(32px, 6vw, 48px) clamp(48px, 8vw, 80px);
    }
    .docs-hero__card {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }
    .docs-hero__title {
      font-size: clamp(40px, 5vw, 64px);
      line-height: 1.05;
      margin: 12px 0 16px;
    }
    .docs-main__title {
      font-size: clamp(32px, 3.5vw, 48px);
      line-height: 1.1;
      margin: 0 0 16px;
    }
    .docs-hero__lede,
    .docs-main__lede {
      margin-bottom: 16px;
    }
    .docs-main .actions {
      margin-top: 0;
    }
  </style>
  <Fragment slot="footer"><Footer /></Fragment>
</Base>
