---
// USMR Phase 5.7 — /roadmap route. Replaces the earlier
// cards/table-toggle composition (5.1c-era) with the canonical
// 5-phase horizontal timeline ported from
// new-design/extracted/src/components/Roadmap.jsx. Drops the
// `RoadmapPhaseCard` / `RoadmapTable` / `public/assets/roadmap.css`
// helpers — those were specific to the toggle UX that the
// new-design canonical removed.
import Base from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import RoadmapTimeline from '../../components/RoadmapTimeline.astro';
---
<Base
  title="Roadmap — Artagon"
  description="From authentication to authority. Five phases, eighteen months — core trust, verifiable credentials, policy engine, proofing & network, federation & AI."
  path="/roadmap"
>
  <Fragment slot="header"><Header /></Fragment>

  <main id="main">
    <RoadmapTimeline />
  </main>

  <Fragment slot="footer"><Footer /></Fragment>
</Base>
