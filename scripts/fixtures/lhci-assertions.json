{
  "$comment": "Lighthouse CI assertion fixture — second SSoT. Paths come from build.config.json; assertion shape comes from this fixture. Sync merges both.",
  "$comment-urls": "Marketing routes that exist TODAY in .build/dist/. The redesign change adds /use-cases/, /standards/, /writing/ — those URLs land here when their /opsx:apply phases ship.",
  "urls": [
    "http://localhost:8081/",
    "http://localhost:8081/platform/",
    "http://localhost:8081/roadmap/",
    "http://localhost:8081/vision/",
    "http://localhost:8081/security/",
    "http://localhost:8081/faq/"
  ],
  "assert": {
    "preset": "lighthouse:no-pwa",
    "assertMatrix": [
      {
        "matchingUrlPattern": "/brand/?$",
        "assertions": {
          "categories:performance": ["error", { "minScore": 0.8 }],
          "categories:accessibility": ["error", { "minScore": 0.95 }],
          "categories:best-practices": ["error", { "minScore": 0.9 }],
          "categories:seo": ["off"]
        }
      },
      {
        "matchingUrlPattern": ".*",
        "assertions": {
          "categories:performance": ["error", { "minScore": 0.9 }],
          "categories:accessibility": ["error", { "minScore": 0.95 }],
          "categories:best-practices": ["error", { "minScore": 0.95 }],
          "categories:seo": ["error", { "minScore": 0.95 }],
          "largest-contentful-paint": ["error", { "maxNumericValue": 2500 }],
          "cumulative-layout-shift": ["error", { "maxNumericValue": 0.1 }],
          "total-blocking-time": ["error", { "maxNumericValue": 200 }],
          "interaction-to-next-paint": ["error", { "maxNumericValue": 200 }]
        }
      }
    ]
  }
}
