#!/usr/bin/env sh
# Pre-commit drift gate per the build-config capability spec.
# Aborts commit if generated configs (lighthouserc.json, lychee.toml) drift
# from build.config.json + scripts/fixtures/lhci-assertions.json.
#
# Spec source: openspec/specs/build-config/spec.md `Pre-commit safety net`
# Requirement (originally authored in the archived
# openspec/changes/archive/2026-05-05-standardize-build-artifacts/ proposal;
# its build-config capability is now the live spec).
#
# Bypass per-commit with `SKIP_BUILD_SYNC=1 git commit ...` (documented as
# a hot-loop opt-out, not for landing PRs — CI re-runs the same check).

if [ "${SKIP_BUILD_SYNC:-0}" = "1" ]; then
  echo "husky/pre-commit: SKIP_BUILD_SYNC=1 — skipping drift gate"
  exit 0
fi

npm run sync:build-config || {
  echo "husky/pre-commit: sync-build-config failed"
  exit 1
}

if ! git diff --exit-code -- lighthouserc.json lychee.toml >/dev/null 2>&1; then
  echo "husky/pre-commit: build config drift — generated files were updated"
  echo "  Stage the changes (git add lighthouserc.json lychee.toml) and re-commit."
  exit 1
fi

# Run lint:design if DESIGN.md is in staged changes (Phase 2.3a).
if git diff --cached --name-only | grep -q "^DESIGN\.md$"; then
  echo "husky/pre-commit: DESIGN.md staged — running lint:design"
  npm run lint:design || {
    echo "husky/pre-commit: lint:design failed"
    exit 1
  }
fi
