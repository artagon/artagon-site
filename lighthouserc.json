{
  "$generated": "build.config.json",
  "$sha": "886935a235c5a3d8",
  "ci": {
    "collect": {
      "staticDistDir": ".build/dist",
      "url": [
        "http://localhost:8081/",
        "http://localhost:8081/platform/",
        "http://localhost:8081/roadmap/",
        "http://localhost:8081/vision/",
        "http://localhost:8081/security/",
        "http://localhost:8081/faq/"
      ]
