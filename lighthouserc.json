                "minScore": 0.8
              }
            ],
            "categories:accessibility": [
              "error",
              {
                "minScore": 0.95
              }
            ],
            "categories:best-practices": [
              "error",
              {
                "minScore": 0.9
              }
            ],
            "categories:seo": [
              "off"
            ]
          }
        },
        {
          "matchingUrlPattern": ".*",
          "assertions": {
            "categories:performance": [
              "error",
              {
                "minScore": 0.9
              }
            ],
            "categories:accessibility": [
              "error",
              {
                "minScore": 0.95
              }
            ],
            "categories:best-practices": [
              "error",
              {
                "minScore": 0.95
              }
            ],
            "categories:seo": [
              "error",
              {
                "minScore": 0.95
              }
            ],
            "largest-contentful-paint": [
              "error",
              {
                "maxNumericValue": 2500
              }
            ],
            "cumulative-layout-shift": [
              "error",
              {
                "maxNumericValue": 0.1
              }
            ],
            "total-blocking-time": [
              "error",
              {
                "maxNumericValue": 200
              }
            ],
            "interaction-to-next-paint": [
              "error",
              {
                "maxNumericValue": 200
              }
            ]
          }
        }
      ]
    },
    "upload": {
      "target": "filesystem",
      "outputDir": ".build/reports/lhci"
    }
  }
