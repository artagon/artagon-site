.DS_Store
node_modules
.env

# Test fixture backups (path-validator test takes a snapshot before mutating
# build.config.json; restored on test exit / SIGTERM).
build.config.json.bak

# Claude Code session-state (in-memory cron lock; should not be tracked).
.claude/scheduled_tasks.lock

# Build umbrella — all runtime artifacts (cache, reports, dist) live here.
# See openspec/specs/build-config/spec.md (originally authored in the
# archived openspec/changes/archive/2026-05-05-standardize-build-artifacts/
# proposal — its build-config capability is now the live spec).
.build/

# Legacy cache locations not yet migrated to .build/ (Astro/MCP write here
# until their tooling supports the new paths). Tracked separately so the
# umbrella line doesn't need exceptions.
.astro/
.playwright-mcp/

# Legacy runtime dirs (Playwright + Astro emitted these before .build/
# migration). Astro now writes to .build/dist/, Playwright to
# .build/reports/playwright/, but stale local copies may linger.
dist/
playwright-report/
test-results/
playwright/.cache/

# Playwright visual-regression snapshot baselines. Only Linux-pinned PNGs
# (*-chromium-linux.png) are committed; the .github/workflows/playwright.yml
# workflow_dispatch job regenerates and auto-commits them on a Linux runner.
# Local Darwin/Windows runs produce host-specific PNGs we don't track.
tests/styling-snapshots.spec.ts-snapshots/*
!tests/styling-snapshots.spec.ts-snapshots/*-chromium-linux.png
tests/device-tour.spec.ts-snapshots/*
!tests/device-tour.spec.ts-snapshots/*-linux.png

# Lychee link-checker cache. The CI workflow now passes
# `--cache-dir .build/cache/lychee` so the cache lives under the .build
# umbrella, but lychee defaults to `.lycheecache/` at repo root if the
# flag is dropped — keep this entry as defense-in-depth.
.lycheecache/

# Working scratch — design handoff zip extracted at session start.
# Tracked artifacts adopted into openspec/changes/add-brand-assets-and-writing-pipeline.
# Directory will be deleted by a future cleanup-new-design-extracted
# change (follow-up to add-brand-assets-and-writing-pipeline +
# update-site-marketing-redesign — referenced as a planned change in
# openspec/project.md, openspec/config.yaml, and FINAL-CROSS-CUTTING-REVIEW.md
# but not yet authored as a proposal). Until then, .gitignore prevents
# new tracked files from accumulating inside the directory.
new-design/

# Agent state — UI review reports, brainstorm notes, etc. Generated by the
# `ui-design:design-review` skill. Lives in working tree as a workspace
# (matches `.workspace/` and `.lighthouseci/` semantics) — not tracked.
.ui-design/

# Lighthouse CI runtime cache (LHCI maintains an `.lighthouseci/` directory
# next to lighthouserc.json with run artifacts). Per the build-config
# capability spec at openspec/specs/build-config/spec.md (originally
# authored in the archived openspec/changes/archive/2026-05-05-standardize-
# build-artifacts/ proposal), generated artifacts MUST live in .build/ —
# but LHCI's path is wired into the CLI and not configurable, so we
# ignore in place.
.lighthouseci/

# Local-only ignore stash. `.gitignore.local` is honored by some tools as
# a parallel ignore layer; not tracked.
.gitignore.local

# Ad-hoc browser screenshots saved by playwright MCP at the repo root
# during interactive review (e.g. `home-final.png`, `platform2.png`).
# These are throwaway capture artifacts; canonical regenerated baselines
# live under `tests/__screenshots__/` and are ignored separately.
/*.png
/*.jpg
/*.jpeg
