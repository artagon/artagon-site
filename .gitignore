.DS_Store
node_modules
.env

# Test fixture backups (path-validator test takes a snapshot before mutating
# build.config.json; restored on test exit / SIGTERM).
build.config.json.bak

# Claude Code session-state (in-memory cron lock; should not be tracked).
.claude/scheduled_tasks.lock

# Build umbrella — all runtime artifacts (cache, reports, dist) live here.
# See openspec/changes/standardize-build-artifacts.
.build/

# Legacy cache locations not yet migrated to .build/ (Astro/MCP write here
# until their tooling supports the new paths). Tracked separately so the
# umbrella line doesn't need exceptions.
.astro/
.playwright-mcp/

# Legacy runtime dirs (Playwright + Astro emitted these before .build/
# migration). Astro now writes to .build/dist/, Playwright to
# .build/reports/playwright/, but stale local copies may linger.
dist/
playwright-report/
test-results/
playwright/.cache/

# Lychee link-checker cache. The CI workflow now passes
# `--cache-dir .build/cache/lychee` so the cache lives under the .build
# umbrella, but lychee defaults to `.lycheecache/` at repo root if the
# flag is dropped — keep this entry as defense-in-depth.
.lycheecache/

# Working scratch — design handoff zip extracted at session start.
# Tracked artifacts adopted into openspec/changes/add-brand-assets-and-writing-pipeline.
# Directory deleted by follow-up cleanup-new-design-extracted change.
new-design/
